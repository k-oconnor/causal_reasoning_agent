02:31:30  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_6.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTELEMETRY_INTERVAL = 5.0\nTARGET_LKO_AP = 90000.0\nTARGET_LKO_PE = 80000.0\nTARGET_MUN_ORBIT_PE = 30000.0\nMAX_MUN_AP = 500000.0\nASCENT_STAGE = 1\nUPPER_STAGE = 0\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef vis_viva(mu, r, a):\n    return math.sqrt(mu * (2.0 / r - 1.0 / a))\n\n\ndef fuel_percent(vessel):\n    try:\n        r = vessel.resources\n        cur = r.amount(\'LiquidFuel\') + r.amount(\'Oxidizer\')\n        maxv = r.max(\'LiquidFuel\') + r.max(\'Oxidizer\')\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef stage_propellant_remaining(vessel, stage):\n    try:\n        r = vessel.resources_in_decouple_stage(stage, cumulative=False)\n        lf = r.amount(\'LiquidFuel\')\n        ox = r.amount(\'Oxidizer\')\n        sf = 0.0\n        try:\n            sf = r.amount(\'SolidFuel\')\n        except Exception:\n            sf = 0.0\n        return lf + ox + sf\n    except Exception:\n        return 9999.0\n\n\ndef burn_time(vessel, delta_v):\n    thrust = max(vessel.available_thrust, vessel.max_thrust, 1.0)\n    isp = max(vessel.specific_impulse * 9.82, 1.0)\n    m0 = vessel.mass\n    mf = m0 / math.exp(delta_v / isp)\n    flow_rate = thrust / isp\n    return max((m0 - mf) / flow_rate, 0.1)\n\n\ndef current_ut(conn):\n    return conn.space_center.ut\n\n\ndef logger(conn, vessel, phase):\n    sc = conn.space_center\n    start_ut = sc.ut\n    last_log_ut = {\'value\': -1e9}\n    flight = vessel.flight(vessel.surface_reference_frame)\n\n    def log(force=False):\n        ut = sc.ut\n        if not force and ut - last_log_ut[\'value\'] < TELEMETRY_INTERVAL:\n            return\n        last_log_ut[\'value\'] = ut\n        print(\n            f"[T+{ut-start_ut:.0f}s] ALT={flight.mean_altitude:.0f}m | "\n            f"SURF_ALT={flight.surface_altitude:.0f}m | SPD={flight.speed:.1f}m/s | "\n            f"AP={vessel.orbit.apoapsis_altitude:.0f}m | PE={vessel.orbit.periapsis_altitude:.0f}m | "\n            f"BODY={vessel.orbit.body.name} | FUEL={fuel_percent(vessel):.1f}% | PHASE={phase[\'name\']}"\n        )\n    return log\n\n\ndef engage_ascent_autopilot(vessel):\n    ap = vessel.auto_pilot\n    ap.disengage()\n    time.sleep(0.2)\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n    return ap\n\n\ndef wait_for_liftoff(vessel, log, timeout=15.0):\n    deadline = time.time() + timeout\n    while time.time() < deadline:\n        if vessel.flight(vessel.surface_reference_frame).surface_altitude > 15.0:\n            return\n        log()\n        time.sleep(0.1)\n    raise RuntimeError(\n        f"Liftoff failure: ALT={vessel.flight(vessel.surface_reference_frame).mean_altitude:.0f} "\n        f"SPD={vessel.flight(vessel.surface_reference_frame).speed:.1f}"\n    )\n\n\ndef coast_until_ut(conn, target_ut, log, hard_limit_s=3600):\n    sc = conn.space_center\n    start = sc.ut\n    while sc.ut < target_ut:\n        if sc.ut - start > hard_limit_s:\n            raise RuntimeError(f\'Coast timeout waiting for UT {target_ut:.1f}\')\n        log()\n        time.sleep(0.1)\n\n\ndef execute_node(conn, vessel, node, log, phase, max_duration=600):\n    sc = conn.space_center\n    ap = vessel.auto_pilot\n    remaining = conn.add_stream(getattr, node, \'remaining_delta_v\')\n    bt = burn_time(vessel, max(node.delta_v, 1.0))\n    burn_start_ut = node.ut - bt / 2.0\n\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.5)\n\n    if sc.ut < burn_start_ut - 90:\n        sc.warp_to(burn_start_ut - 25)\n    coast_until_ut(conn, burn_start_ut, log, hard_limit_s=max_duration)\n\n    t0 = time.time()\n    vessel.control.throttle = 1.0\n    last_remaining = None\n    stagnant_cycles = 0\n\n    while remaining() > 20.0:\n        log()\n        cur = remaining()\n        if last_remaining is not None and abs(cur - last_remaining) < 0.02:\n            stagnant_cycles += 1\n        else:\n            stagnant_cycles = 0\n        if stagnant_cycles > 80:\n            raise RuntimeError(f\'Node burn stalled with remaining_dv={cur:.2f}\')\n        last_remaining = cur\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node burn timeout with remaining_dv={cur:.2f}\')\n        time.sleep(0.05)\n\n    vessel.control.throttle = 0.25\n    while remaining() > 2.0:\n        log()\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Fine burn timeout with remaining_dv={remaining():.2f}\')\n        time.sleep(0.05)\n\n    vessel.control.throttle = 0.08\n    while remaining() > 0.35:\n        log()\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Final trim timeout with remaining_dv={remaining():.2f}\')\n        time.sleep(0.05)\n\n    vessel.control.throttle = 0.0\n    time.sleep(0.3)\n    node.remove()\n\n\ndef required_phase_angle(mu, r_departure, r_target):\n    a_transfer = 0.5 * (r_departure + r_target)\n    t_transfer = math.pi * math.sqrt(a_transfer ** 3 / mu)\n    target_rate = math.sqrt(mu / r_target ** 3)\n    return (math.pi - target_rate * t_transfer) % (2.0 * math.pi)\n\n\ndef current_phase_angle(vessel, target_body, parent_body):\n    frame = parent_body.non_rotating_reference_frame\n    vp = vessel.position(frame)\n    tp = target_body.position(frame)\n    vessel_angle = math.atan2(vp[1], vp[0])\n    target_angle = math.atan2(tp[1], tp[0])\n    return (target_angle - vessel_angle) % (2.0 * math.pi)\n\n\ndef plan_best_tmi_node(conn, vessel, mun, base_ut, base_dv):\n    best = None\n    best_score = 1e30\n    time_offsets = [-240, -180, -120, -60, -30, 0, 30, 60, 120, 180, 240]\n    dv_offsets = [-120, -80, -40, -20, 0, 20, 40, 80, 120]\n\n    for dt in time_offsets:\n        for ddv in dv_offsets:\n            node = vessel.control.add_node(base_ut + dt, prograde=base_dv + ddv)\n            try:\n                next_orbit = node.orbit.next_orbit\n                hit = next_orbit is not None and next_orbit.body.name == \'Mun\'\n                closest = node.orbit.distance_at_closest_approach(mun.orbit)\n                score = closest - (1e9 if hit else 0.0)\n                if score < best_score:\n                    best_score = score\n                    best = {\n                        \'ut\': base_ut + dt,\n                        \'dv\': base_dv + ddv,\n                        \'hit\': hit,\n                        \'closest\': closest,\n                    }\n            finally:\n                node.remove()\n    return best\n\n\ndef wait_for_mun_window(conn, vessel, kerbin, mun, log, phase):\n    sc = conn.space_center\n    mu = kerbin.gravitational_parameter\n    r_departure = vessel.orbit.semi_major_axis\n    r_target = mun.orbit.semi_major_axis\n    needed = required_phase_angle(mu, r_departure, r_target)\n    vessel_rate = math.sqrt(mu / r_departure ** 3)\n    mun_rate = math.sqrt(mu / r_target ** 3)\n    rel_rate = vessel_rate - mun_rate\n\n    if rel_rate <= 0:\n        return\n\n    while True:\n        current = current_phase_angle(vessel, mun, kerbin)\n        err = (needed - current) % (2.0 * math.pi)\n        if err > math.pi:\n            err -= 2.0 * math.pi\n        log()\n        if abs(err) < math.radians(2.0):\n            return\n        wait_s = abs(err) / rel_rate\n        if wait_s > 180:\n            sc.warp_to(sc.ut + wait_s - 90)\n        else:\n            time.sleep(0.2)\n\n\ndef ascent_to_target_apoapsis(conn, vessel, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n    ap = engage_ascent_autopilot(vessel)\n\n    phase[\'name\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    wait_for_liftoff(vessel, log)\n\n    stage_sep_done = False\n    flameout_confirm = 0\n\n    while True:\n        flight = vessel.flight(vessel.surface_reference_frame)\n        alt = flight.mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        q = flight.dynamic_pressure\n\n        if alt < 1000:\n            pitch = 90.0\n        elif alt < 10000:\n            pitch = 90.0 - 45.0 * ((alt - 1000.0) / 9000.0)\n        elif alt < 45000:\n            pitch = 45.0 - 35.0 * ((alt - 10000.0) / 35000.0)\n        else:\n            pitch = 10.0\n        pitch = clamp(pitch, 5.0, 90.0)\n        ap.target_pitch_and_heading(pitch, 90.0)\n\n        if q > 30000:\n            control.throttle = 0.45\n        elif q > 20000:\n            control.throttle = 0.65\n        else:\n            control.throttle = 1.0\n\n        if not stage_sep_done:\n            stage_fuel = stage_propellant_remaining(vessel, ASCENT_STAGE)\n            if stage_fuel < 1.0 or vessel.available_thrust < 10.0:\n                flameout_confirm += 1\n            else:\n                flameout_confirm = 0\n            if flameout_confirm >= 5:\n                control.throttle = 0.0\n                time.sleep(0.3)\n                control.activate_next_stage()\n                time.sleep(1.5)\n                control.throttle = 1.0\n                stage_sep_done = True\n\n        log()\n\n        if ap_alt >= TARGET_LKO_AP and alt < 70000:\n            control.throttle = 0.0\n            break\n\n        if alt > 70000 and ap_alt < TARGET_LKO_AP:\n            raise RuntimeError(\n                f\'Ascent failure: left atmosphere before target apoapsis. ALT={alt:.0f} AP={ap_alt:.0f}\'\n            )\n\n        if vessel.situation.name.lower() in (\'dead\', \'splashed\'):\n            raise RuntimeError(\'Vehicle lost during ascent\')\n\n        time.sleep(0.05)\n\n\ndef circularize(conn, vessel, kerbin, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'COAST_TO_AP\'\n    if vessel.orbit.time_to_apoapsis > 120:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_apoapsis - 45)\n    while vessel.orbit.time_to_apoapsis > 15:\n        log()\n        time.sleep(0.1)\n\n    phase[\'name\'] = \'CIRCULARIZATION\'\n    mu = kerbin.gravitational_parameter\n    r = vessel.orbit.apoapsis\n    a1 = vessel.orbit.semi_major_axis\n    dv = vis_viva(mu, r, r) - vis_viva(mu, r, a1)\n    node = control.add_node(sc.ut + vessel.orbit.time_to_apoapsis, prograde=dv)\n    execute_node(conn, vessel, node, log, phase, max_duration=240)\n\n    if vessel.orbit.periapsis_altitude < TARGET_LKO_PE:\n        raise RuntimeError(\n            f\'Failed circularization: PE={vessel.orbit.periapsis_altitude:.0f} BODY={vessel.orbit.body.name}\'\n        )\n    if vessel.orbit.body.name != \'Kerbin\':\n        raise RuntimeError(f\'Unexpected body after circularization: BODY={vessel.orbit.body.name}\')\n\n\ndef trans_mun_injection(conn, vessel, kerbin, mun, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'WAIT_TMI_WINDOW\'\n    wait_for_mun_window(conn, vessel, kerbin, mun, log, phase)\n\n    phase[\'name\'] = \'PLAN_TMI\'\n    r_departure = vessel.orbit.semi_major_axis\n    r_target = mun.orbit.semi_major_axis\n    mu = kerbin.gravitational_parameter\n    a_transfer = 0.5 * (r_departure + r_target)\n    v_circ = math.sqrt(mu / r_departure)\n    v_trans = math.sqrt(mu * (2.0 / r_departure - 1.0 / a_transfer))\n    base_dv = max(0.0, v_trans - v_circ)\n    base_ut = sc.ut + vessel.orbit.time_to_apoapsis\n\n    best = plan_best_tmi_node(conn, vessel, mun, base_ut, base_dv)\n    if best is None:\n        raise RuntimeError(\'TMI planning failure: no candidate nodes evaluated\')\n    if not best[\'hit\'] and best[\'closest\'] > mun.sphere_of_influence:\n        raise RuntimeError(\n            f"TMI planning failure: no Mun encounter found; closest={best[\'closest\']:.0f} m"\n        )\n\n    node = control.add_node(best[\'ut\'], prograde=best[\'dv\'])\n    phase[\'name\'] = \'EXECUTE_TMI\'\n    execute_node(conn, vessel, node, log, phase, max_duration=420)\n\n    next_orbit = vessel.orbit.next_orbit\n    if next_orbit is None or next_orbit.body.name != \'Mun\':\n        raise RuntimeError(\'TMI failed: no Mun encounter predicted after burn\')\n\n\ndef mun_orbit_insertion(conn, vessel, mun, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'COAST_TO_MUN\'\n    t_soi = vessel.orbit.time_to_soi_change\n    if not math.isnan(t_soi) and t_soi > 180:\n        sc.warp_to(sc.ut + t_soi - 90)\n\n    soi_deadline = time.time() + 1800\n    while vessel.orbit.body.name == \'Kerbin\':\n        log()\n        if time.time() > soi_deadline:\n            raise RuntimeError(\'SOI transfer timeout before Mun encounter\')\n        time.sleep(0.2)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f\'SOI failure: BODY={vessel.orbit.body.name}\')\n\n    phase[\'name\'] = \'PLAN_MOI\'\n    if vessel.orbit.time_to_periapsis > 120:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_periapsis - 40)\n    while vessel.orbit.time_to_periapsis > 10:\n        log()\n        time.sleep(0.1)\n\n    mu = mun.gravitational_parameter\n    r = vessel.orbit.periapsis\n    a = vessel.orbit.semi_major_axis\n    v_peri = vis_viva(mu, r, a)\n    target_r = mun.equatorial_radius + TARGET_MUN_ORBIT_PE\n    v_circ = math.sqrt(mu / target_r)\n    dv = max(0.0, v_peri - v_circ)\n\n    node = control.add_node(sc.ut + vessel.orbit.time_to_periapsis, prograde=-dv)\n    phase[\'name\'] = \'MOI\'\n    execute_node(conn, vessel, node, log, phase, max_duration=300)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f\'Post-MOI wrong body: BODY={vessel.orbit.body.name}\')\n    if vessel.orbit.periapsis_altitude < 10000:\n        raise RuntimeError(f\'Post-MOI periapsis too low: PE={vessel.orbit.periapsis_altitude:.0f}\')\n    if vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n        raise RuntimeError(f\'Post-MOI apoapsis too high: AP={vessel.orbit.apoapsis_altitude:.0f}\')\n\n\ndef verify_one_orbit(conn, vessel, log, phase):\n    sc = conn.space_center\n    phase[\'name\'] = \'VERIFY_ONE_ORBIT\'\n    end_ut = sc.ut + vessel.orbit.period\n    while sc.ut < end_ut:\n        vessel.control.throttle = 0.0\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            raise RuntimeError(\'Verification failure: left Mun orbit\')\n        if vessel.orbit.periapsis_altitude < 10000:\n            raise RuntimeError(f\'Verification failure: PE={vessel.orbit.periapsis_altitude:.0f}\')\n        if vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n            raise RuntimeError(f\'Verification failure: AP={vessel.orbit.apoapsis_altitude:.0f}\')\n        time.sleep(0.5)\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    kerbin = sc.bodies[\'Kerbin\']\n    mun = sc.bodies[\'Mun\']\n\n    phase = {\'name\': \'PRELAUNCH\'}\n    log = logger(conn, vessel, phase)\n\n    vessel.control.sas = False\n    vessel.control.rcs = False\n    vessel.control.throttle = 0.0\n    vessel.auto_pilot.disengage()\n    time.sleep(0.5)\n\n    ascent_to_target_apoapsis(conn, vessel, log, phase)\n    circularize(conn, vessel, kerbin, log, phase)\n    trans_mun_injection(conn, vessel, kerbin, mun, log, phase)\n    mun_orbit_insertion(conn, vessel, mun, log, phase)\n    verify_one_orbit(conn, vessel, log, phase)\n\n    phase[\'name\'] = \'MISSION_SUCCESS\'\n    log(force=True)\n    print(\'MISSION SUCCESS: stable Mun orbit sustained for one full orbit.\')\n\n\nif __name__ == \'__main__\':\n    try:\n        main()\n    except Exception as exc:\n        print(\'MISSION FAILURE\')\n        print(str(exc))\n        traceback.print_exc()\n        raise\n'})
