02:42:44  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_7.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTELEMETRY_INTERVAL = 5.0\nTARGET_LKO_AP = 90000.0\nTARGET_LKO_PE = 80000.0\nTARGET_MUN_ORBIT_PE = 30000.0\nMAX_MUN_AP = 500000.0\nASCENT_STAGE = 1\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef vis_viva(mu, r, a):\n    return math.sqrt(mu * (2.0 / r - 1.0 / a))\n\n\ndef fuel_percent(vessel):\n    try:\n        r = vessel.resources\n        cur = r.amount(\'LiquidFuel\') + r.amount(\'Oxidizer\')\n        maxv = r.max(\'LiquidFuel\') + r.max(\'Oxidizer\')\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef stage_propellant_remaining(vessel, stage):\n    try:\n        r = vessel.resources_in_decouple_stage(stage, cumulative=False)\n        total = 0.0\n        for name in (\'LiquidFuel\', \'Oxidizer\', \'SolidFuel\'):\n            try:\n                total += r.amount(name)\n            except Exception:\n                pass\n        return total\n    except Exception:\n        return 9999.0\n\n\ndef burn_time(vessel, delta_v):\n    thrust = max(vessel.available_thrust, vessel.max_thrust, 1.0)\n    isp = max(vessel.specific_impulse * 9.82, 1.0)\n    m0 = vessel.mass\n    mf = m0 / math.exp(delta_v / isp)\n    flow = thrust / isp\n    return max((m0 - mf) / flow, 0.1)\n\n\ndef logger(conn, vessel, phase):\n    sc = conn.space_center\n    start_ut = sc.ut\n    last_ut = {\'v\': -1e9}\n    flight = vessel.flight(vessel.surface_reference_frame)\n\n    def log(force=False):\n        ut = sc.ut\n        if not force and ut - last_ut[\'v\'] < TELEMETRY_INTERVAL:\n            return\n        last_ut[\'v\'] = ut\n        print(\n            f"[T+{ut-start_ut:.0f}s] ALT={flight.mean_altitude:.0f}m | SURF_ALT={flight.surface_altitude:.0f}m | "\n            f"SPD={flight.speed:.1f}m/s | AP={vessel.orbit.apoapsis_altitude:.0f}m | PE={vessel.orbit.periapsis_altitude:.0f}m | "\n            f"BODY={vessel.orbit.body.name} | FUEL={fuel_percent(vessel):.1f}% | PHASE={phase[\'name\']}"\n        )\n    return log\n\n\ndef wait_for_liftoff(vessel, log):\n    deadline = time.time() + 15.0\n    while time.time() < deadline:\n        if vessel.flight(vessel.surface_reference_frame).surface_altitude > 15.0:\n            return\n        log()\n        time.sleep(0.1)\n    raise RuntimeError(\'Liftoff failure\')\n\n\ndef point_to_node(vessel, node):\n    ap = vessel.auto_pilot\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.5)\n\n\ndef execute_node(conn, vessel, node, log, phase, max_duration=700):\n    sc = conn.space_center\n    point_to_node(vessel, node)\n    rem = conn.add_stream(getattr, node, \'remaining_delta_v\')\n    bt = burn_time(vessel, max(node.delta_v, 1.0))\n    start_ut = node.ut - bt / 2.0\n\n    if sc.ut < start_ut - 90:\n        sc.warp_to(start_ut - 20)\n    while sc.ut < start_ut:\n        log()\n        time.sleep(0.1)\n\n    t0 = time.time()\n    vessel.control.throttle = 1.0\n    while rem() > 20.0:\n        log()\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node burn timeout rem_dv={rem():.2f}\')\n        time.sleep(0.05)\n    vessel.control.throttle = 0.25\n    while rem() > 2.0:\n        log()\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node trim timeout rem_dv={rem():.2f}\')\n        time.sleep(0.05)\n    vessel.control.throttle = 0.08\n    while rem() > 0.3:\n        log()\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node final timeout rem_dv={rem():.2f}\')\n        time.sleep(0.05)\n    vessel.control.throttle = 0.0\n    time.sleep(0.3)\n    node.remove()\n\n\ndef required_phase_angle(mu, r1, r2):\n    a = 0.5 * (r1 + r2)\n    t = math.pi * math.sqrt(a ** 3 / mu)\n    target_rate = math.sqrt(mu / r2 ** 3)\n    return (math.pi - target_rate * t) % (2.0 * math.pi)\n\n\ndef current_phase_angle(vessel, target_body, parent_body):\n    frame = parent_body.non_rotating_reference_frame\n    vp = vessel.position(frame)\n    tp = target_body.position(frame)\n    va = math.atan2(vp[1], vp[0])\n    ta = math.atan2(tp[1], tp[0])\n    return (ta - va) % (2.0 * math.pi)\n\n\ndef coast_with_logs_until(conn, target_ut, log):\n    while conn.space_center.ut < target_ut:\n        log()\n        time.sleep(0.1)\n\n\ndef plan_tmi_with_refinement(conn, vessel, mun, base_ut, base_dv):\n    best = None\n    best_score = 1e30\n    grids = [\n        ([-300, -180, -120, -60, 0, 60, 120, 180, 300], [-140, -100, -60, -30, 0, 30, 60, 100, 140]),\n        ([-90, -60, -30, -15, 0, 15, 30, 60, 90], [-50, -30, -15, -8, 0, 8, 15, 30, 50]),\n        ([-20, -10, -5, 0, 5, 10, 20], [-12, -8, -4, 0, 4, 8, 12]),\n    ]\n\n    center_ut = base_ut\n    center_dv = base_dv\n\n    for time_offsets, dv_offsets in grids:\n        local_best = None\n        local_best_score = 1e30\n        for dt in time_offsets:\n            for ddv in dv_offsets:\n                node = vessel.control.add_node(center_ut + dt, prograde=center_dv + ddv)\n                try:\n                    next_orbit = node.orbit.next_orbit\n                    hit = next_orbit is not None and next_orbit.body.name == \'Mun\'\n                    closest = node.orbit.distance_at_closest_approach(mun.orbit)\n                    score = closest - (1e9 if hit else 0.0)\n                    if score < local_best_score:\n                        local_best_score = score\n                        local_best = {\n                            \'ut\': center_ut + dt,\n                            \'dv\': center_dv + ddv,\n                            \'hit\': hit,\n                            \'closest\': closest,\n                        }\n                finally:\n                    node.remove()\n        if local_best is None:\n            break\n        best = local_best\n        best_score = local_best_score\n        center_ut = local_best[\'ut\']\n        center_dv = local_best[\'dv\']\n\n    return best, best_score\n\n\ndef do_midcourse_correction(conn, vessel, mun, log, phase):\n    sc = conn.space_center\n    if vessel.orbit.body.name != \'Kerbin\':\n        return\n    t_soi = vessel.orbit.time_to_soi_change\n    if math.isnan(t_soi) or t_soi < 900:\n        return\n\n    phase[\'name\'] = \'MIDCOURSE_CORRECTION\'\n    correction_ut = sc.ut + t_soi * 0.5\n    if correction_ut - sc.ut > 300:\n        sc.warp_to(correction_ut - 60)\n    while sc.ut < correction_ut:\n        log()\n        time.sleep(0.1)\n\n    best = None\n    best_score = 1e30\n    for pro in [-30, -20, -10, -5, 0, 5, 10, 20, 30]:\n        for normal in [-20, -10, -5, 0, 5, 10, 20]:\n            for radial in [-20, -10, -5, 0, 5, 10, 20]:\n                node = vessel.control.add_node(sc.ut + 60, prograde=pro, normal=normal, radial=radial)\n                try:\n                    next_orbit = node.orbit.next_orbit\n                    hit = next_orbit is not None and next_orbit.body.name == \'Mun\'\n                    closest = node.orbit.distance_at_closest_approach(mun.orbit)\n                    score = closest - (1e9 if hit else 0.0)\n                    if score < best_score:\n                        best_score = score\n                        best = {\'prograde\': pro, \'normal\': normal, \'radial\': radial, \'hit\': hit, \'closest\': closest}\n                finally:\n                    node.remove()\n\n    if best is None:\n        return\n    if not best[\'hit\'] and best[\'closest\'] >= mun.sphere_of_influence:\n        return\n\n    node = vessel.control.add_node(sc.ut + 60, prograde=best[\'prograde\'], normal=best[\'normal\'], radial=best[\'radial\'])\n    execute_node(conn, vessel, node, log, phase, max_duration=180)\n\n\ndef ascent(conn, vessel, log, phase):\n    control = vessel.control\n    ap = vessel.auto_pilot\n    ap.disengage()\n    time.sleep(0.2)\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n\n    phase[\'name\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    wait_for_liftoff(vessel, log)\n\n    stage_sep_done = False\n    empty_count = 0\n\n    while True:\n        fl = vessel.flight(vessel.surface_reference_frame)\n        alt = fl.mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        q = fl.dynamic_pressure\n\n        if alt < 1000:\n            pitch = 90\n        elif alt < 10000:\n            pitch = 90 - 45 * ((alt - 1000) / 9000.0)\n        elif alt < 45000:\n            pitch = 45 - 35 * ((alt - 10000) / 35000.0)\n        else:\n            pitch = 10\n        pitch = clamp(pitch, 5, 90)\n        ap.target_pitch_and_heading(pitch, 90)\n\n        if q > 30000:\n            control.throttle = 0.45\n        elif q > 20000:\n            control.throttle = 0.65\n        else:\n            control.throttle = 1.0\n\n        if not stage_sep_done:\n            if stage_propellant_remaining(vessel, ASCENT_STAGE) < 1.0 or vessel.available_thrust < 10.0:\n                empty_count += 1\n            else:\n                empty_count = 0\n            if empty_count >= 5:\n                control.throttle = 0.0\n                time.sleep(0.3)\n                control.activate_next_stage()\n                time.sleep(1.5)\n                control.throttle = 1.0\n                stage_sep_done = True\n\n        log()\n        if ap_alt >= TARGET_LKO_AP and alt < 70000:\n            control.throttle = 0.0\n            return\n        if alt > 70000 and ap_alt < TARGET_LKO_AP:\n            raise RuntimeError(f\'Ascent failure ALT={alt:.0f} AP={ap_alt:.0f}\')\n        time.sleep(0.05)\n\n\ndef circularize(conn, vessel, kerbin, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'COAST_TO_AP\'\n    if vessel.orbit.time_to_apoapsis > 120:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_apoapsis - 45)\n    while vessel.orbit.time_to_apoapsis > 12:\n        log()\n        time.sleep(0.1)\n\n    phase[\'name\'] = \'CIRCULARIZATION\'\n    mu = kerbin.gravitational_parameter\n    r = vessel.orbit.apoapsis\n    a1 = vessel.orbit.semi_major_axis\n    dv = vis_viva(mu, r, r) - vis_viva(mu, r, a1)\n    node = control.add_node(sc.ut + vessel.orbit.time_to_apoapsis, prograde=dv)\n    execute_node(conn, vessel, node, log, phase, max_duration=240)\n\n    if vessel.orbit.periapsis_altitude < TARGET_LKO_PE or vessel.orbit.body.name != \'Kerbin\':\n        raise RuntimeError(\n            f\'Circularization failure PE={vessel.orbit.periapsis_altitude:.0f} BODY={vessel.orbit.body.name}\'\n        )\n\n\ndef tmi(conn, vessel, kerbin, mun, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'WAIT_TMI_WINDOW\'\n    mu = kerbin.gravitational_parameter\n    r1 = vessel.orbit.semi_major_axis\n    r2 = mun.orbit.semi_major_axis\n    need = required_phase_angle(mu, r1, r2)\n    rate = math.sqrt(mu / r1 ** 3) - math.sqrt(mu / r2 ** 3)\n\n    while True:\n        cur = current_phase_angle(vessel, mun, kerbin)\n        err = (need - cur) % (2 * math.pi)\n        if err > math.pi:\n            err -= 2 * math.pi\n        log()\n        if abs(err) < math.radians(1.0):\n            break\n        wait_s = abs(err) / max(rate, 1e-9)\n        if wait_s > 180:\n            sc.warp_to(sc.ut + wait_s - 90)\n        else:\n            time.sleep(0.2)\n\n    phase[\'name\'] = \'PLAN_TMI\'\n    a = 0.5 * (r1 + r2)\n    v1 = math.sqrt(mu / r1)\n    vt = math.sqrt(mu * (2.0 / r1 - 1.0 / a))\n    base_dv = max(0.0, vt - v1)\n    base_ut = sc.ut + vessel.orbit.time_to_apoapsis\n\n    best, score = plan_tmi_with_refinement(conn, vessel, mun, base_ut, base_dv)\n    if best is None:\n        raise RuntimeError(\'TMI planning failure: no best node\')\n    if not best[\'hit\'] and best[\'closest\'] > mun.sphere_of_influence * 1.25:\n        raise RuntimeError(f"TMI planning failure closest={best[\'closest\']:.0f}")\n\n    node = control.add_node(best[\'ut\'], prograde=best[\'dv\'])\n    phase[\'name\'] = \'EXECUTE_TMI\'\n    execute_node(conn, vessel, node, log, phase, max_duration=420)\n\n    next_orbit = vessel.orbit.next_orbit\n    if next_orbit is None or next_orbit.body.name != \'Mun\':\n        do_midcourse_correction(conn, vessel, mun, log, phase)\n\n    next_orbit = vessel.orbit.next_orbit\n    if next_orbit is None or next_orbit.body.name != \'Mun\':\n        raise RuntimeError(\'TMI failed: no Mun encounter after transfer and correction\')\n\n\ndef moi(conn, vessel, mun, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'COAST_TO_MUN\'\n    t_soi = vessel.orbit.time_to_soi_change\n    if not math.isnan(t_soi) and t_soi > 180:\n        sc.warp_to(sc.ut + t_soi - 90)\n\n    deadline = time.time() + 1800\n    while vessel.orbit.body.name == \'Kerbin\':\n        log()\n        if time.time() > deadline:\n            raise RuntimeError(\'Mun coast timeout\')\n        time.sleep(0.2)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f\'SOI failure BODY={vessel.orbit.body.name}\')\n\n    phase[\'name\'] = \'PLAN_MOI\'\n    if vessel.orbit.time_to_periapsis > 120:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_periapsis - 40)\n    while vessel.orbit.time_to_periapsis > 10:\n        log()\n        time.sleep(0.1)\n\n    mu = mun.gravitational_parameter\n    r = vessel.orbit.periapsis\n    a = vessel.orbit.semi_major_axis\n    v_peri = vis_viva(mu, r, a)\n    target_r = mun.equatorial_radius + TARGET_MUN_ORBIT_PE\n    v_circ = math.sqrt(mu / target_r)\n    dv = max(0.0, v_peri - v_circ)\n\n    node = control.add_node(sc.ut + vessel.orbit.time_to_periapsis, prograde=-dv)\n    phase[\'name\'] = \'MOI\'\n    execute_node(conn, vessel, node, log, phase, max_duration=300)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f\'Wrong body after MOI: {vessel.orbit.body.name}\')\n    if vessel.orbit.periapsis_altitude < 10000:\n        raise RuntimeError(f\'Low Mun periapsis: {vessel.orbit.periapsis_altitude:.0f}\')\n    if vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n        raise RuntimeError(f\'High Mun apoapsis: {vessel.orbit.apoapsis_altitude:.0f}\')\n\n\ndef verify(conn, vessel, log, phase):\n    sc = conn.space_center\n    phase[\'name\'] = \'VERIFY_ONE_ORBIT\'\n    end_ut = sc.ut + vessel.orbit.period\n    while sc.ut < end_ut:\n        vessel.control.throttle = 0.0\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            raise RuntimeError(\'Verification failed: left Mun SOI\')\n        if vessel.orbit.periapsis_altitude < 10000:\n            raise RuntimeError(f\'Verification periapsis failure: {vessel.orbit.periapsis_altitude:.0f}\')\n        if vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n            raise RuntimeError(f\'Verification apoapsis failure: {vessel.orbit.apoapsis_altitude:.0f}\')\n        time.sleep(0.5)\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    kerbin = sc.bodies[\'Kerbin\']\n    mun = sc.bodies[\'Mun\']\n\n    vessel.control.sas = False\n    vessel.control.rcs = False\n    vessel.control.throttle = 0.0\n    vessel.auto_pilot.disengage()\n    time.sleep(0.5)\n\n    phase = {\'name\': \'PRELAUNCH\'}\n    log = logger(conn, vessel, phase)\n\n    ascent(conn, vessel, log, phase)\n    circularize(conn, vessel, kerbin, log, phase)\n    tmi(conn, vessel, kerbin, mun, log, phase)\n    moi(conn, vessel, mun, log, phase)\n    verify(conn, vessel, log, phase)\n\n    phase[\'name\'] = \'MISSION_SUCCESS\'\n    log(force=True)\n    print(\'MISSION SUCCESS: stable Mun orbit sustained for one full orbit.\')\n\n\nif __name__ == \'__main__\':\n    try:\n        main()\n    except Exception as exc:\n        print(\'MISSION FAILURE\')\n        print(str(exc))\n        traceback.print_exc()\n        raise\n'})
