02:17:41  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_5.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTELEMETRY_INTERVAL = 5.0\nTARGET_AP = 90000.0\nTARGET_PE = 80000.0\nTARGET_MUN_PE = 30000.0\nMAX_MUN_AP = 500000.0\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef vis_viva(mu, r, a):\n    return math.sqrt(mu * (2.0 / r - 1.0 / a))\n\n\ndef burn_time(vessel, dv):\n    thrust = max(vessel.available_thrust, vessel.max_thrust, 1.0)\n    isp = max(vessel.specific_impulse * 9.82, 1.0)\n    m0 = vessel.mass\n    mf = m0 / math.exp(dv / isp)\n    flow = thrust / isp\n    return max((m0 - mf) / flow, 0.1)\n\n\ndef fuel_percent(vessel):\n    try:\n        r = vessel.resources\n        cur = r.amount(\'LiquidFuel\') + r.amount(\'Oxidizer\')\n        maxv = r.max(\'LiquidFuel\') + r.max(\'Oxidizer\')\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef logger(conn, vessel, phase):\n    start_ut = conn.space_center.ut\n    last_ut = {\'v\': -1e9}\n\n    def log(force=False):\n        ut = conn.space_center.ut\n        if not force and ut - last_ut[\'v\'] < TELEMETRY_INTERVAL:\n            return\n        last_ut[\'v\'] = ut\n        fl = vessel.flight()\n        print(\n            f"[T+{ut-start_ut:.0f}s] ALT={fl.mean_altitude:.0f}m | SURF_ALT={fl.surface_altitude:.0f}m | "\n            f"SPD={fl.speed:.1f}m/s | AP={vessel.orbit.apoapsis_altitude:.0f}m | PE={vessel.orbit.periapsis_altitude:.0f}m | "\n            f"BODY={vessel.orbit.body.name} | FUEL={fuel_percent(vessel):.1f}% | PHASE={phase[\'name\']}"\n        )\n    return log\n\n\ndef wait_for_liftoff(vessel, log):\n    deadline = time.time() + 12.0\n    while time.time() < deadline:\n        log()\n        if vessel.flight().surface_altitude > 20.0:\n            return\n        time.sleep(0.1)\n    raise RuntimeError(f"Liftoff failure: ALT={vessel.flight().mean_altitude:.0f} SPD={vessel.flight().speed:.1f}")\n\n\ndef execute_node(conn, vessel, node, log, phase):\n    sc = conn.space_center\n    ap = vessel.auto_pilot\n    phase[\'name\'] = phase[\'name\']\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.0)\n\n    remaining = conn.add_stream(getattr, node, \'remaining_delta_v\')\n    bt = burn_time(vessel, max(node.delta_v, 1.0))\n    start_ut = node.ut - bt / 2.0\n    if sc.ut < start_ut - 60:\n        sc.warp_to(start_ut - 20)\n    while sc.ut < start_ut:\n        log()\n        time.sleep(0.05)\n\n    vessel.control.throttle = 1.0\n    while remaining() > 20.0:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.25\n    while remaining() > 2.0:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.08\n    while remaining() > 0.3:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.0\n    time.sleep(0.5)\n    node.remove()\n\n\ndef required_phase_angle(mu, r_departure, r_target):\n    a_transfer = 0.5 * (r_departure + r_target)\n    t_transfer = math.pi * math.sqrt(a_transfer ** 3 / mu)\n    target_rate = math.sqrt(mu / r_target ** 3)\n    return (math.pi - target_rate * t_transfer) % (2.0 * math.pi)\n\n\ndef signed_phase(vessel, target_body, parent_body):\n    frame = parent_body.non_rotating_reference_frame\n    vp = vessel.position(frame)\n    vv = vessel.velocity(frame)\n    tp = target_body.position(frame)\n    vpa = math.atan2(vp[1], vp[0])\n    tpa = math.atan2(tp[1], tp[0])\n    ang = (tpa - vpa) % (2.0 * math.pi)\n    return ang\n\n\ndef find_best_mun_node(conn, vessel, mun, base_ut, base_dv):\n    best = None\n    best_score = 1e30\n    for dt in [-180, -120, -60, -30, 0, 30, 60, 120, 180]:\n        for ddv in [-120, -80, -40, -20, 0, 20, 40, 80, 120]:\n            node = vessel.control.add_node(base_ut + dt, prograde=base_dv + ddv)\n            try:\n                nxt = node.orbit.next_orbit\n                closest = node.orbit.distance_at_closest_approach(mun.orbit)\n                hit = nxt is not None and nxt.body.name == \'Mun\'\n                score = closest - (1e9 if hit else 0.0)\n                if score < best_score:\n                    best_score = score\n                    best = (base_ut + dt, base_dv + ddv, hit, closest)\n            except Exception:\n                pass\n            finally:\n                node.remove()\n    return best\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    kerbin = sc.bodies[\'Kerbin\']\n    mun = sc.bodies[\'Mun\']\n    control = vessel.control\n    ap = vessel.auto_pilot\n\n    phase = {\'name\': \'PRELAUNCH\'}\n    log = logger(conn, vessel, phase)\n\n    control.sas = False\n    control.rcs = False\n    control.throttle = 0.0\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n    time.sleep(1.0)\n\n    # Phase 1: ascent\n    phase[\'name\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    wait_for_liftoff(vessel, log)\n\n    staged = False\n    while True:\n        fl = vessel.flight()\n        alt = fl.mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        q = fl.dynamic_pressure\n\n        if alt < 1500:\n            pitch = 90\n        elif alt < 10000:\n            pitch = 90 - 45 * ((alt - 1500) / 8500.0)\n        elif alt < 45000:\n            pitch = 45 - 35 * ((alt - 10000) / 35000.0)\n        else:\n            pitch = 10\n        pitch = clamp(pitch, 5, 90)\n        ap.target_pitch_and_heading(pitch, 90)\n\n        if q > 30000:\n            control.throttle = 0.45\n        elif q > 20000:\n            control.throttle = 0.65\n        else:\n            control.throttle = 1.0\n\n        if not staged and vessel.available_thrust < 10.0:\n            control.activate_next