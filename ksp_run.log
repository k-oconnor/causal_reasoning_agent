03:19:24  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_9.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTELEMETRY_INTERVAL = 5.0\nTARGET_LKO_AP = 90000.0\nTARGET_LKO_PE = 80000.0\nTARGET_MUN_PE = 30000.0\nMAX_MUN_AP = 500000.0\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef vis_viva(mu, r, a):\n    return math.sqrt(mu * (2.0 / r - 1.0 / a))\n\n\ndef fuel_percent(vessel):\n    try:\n        r = vessel.resources\n        cur = r.amount(\'LiquidFuel\') + r.amount(\'Oxidizer\')\n        maxv = r.max(\'LiquidFuel\') + r.max(\'Oxidizer\')\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef burn_time(vessel, delta_v):\n    thrust = max(vessel.available_thrust, vessel.max_thrust, 1.0)\n    isp = max(vessel.specific_impulse * 9.82, 1.0)\n    m0 = vessel.mass\n    mf = m0 / math.exp(delta_v / isp)\n    flow = thrust / isp\n    return max((m0 - mf) / flow, 0.1)\n\n\ndef logger(conn, vessel, phase):\n    sc = conn.space_center\n    start_ut = sc.ut\n    last_ut = {\'v\': -1e9}\n    flight = vessel.flight(vessel.surface_reference_frame)\n\n    def log(force=False):\n        ut = sc.ut\n        if not force and ut - last_ut[\'v\'] < TELEMETRY_INTERVAL:\n            return\n        last_ut[\'v\'] = ut\n        print(\n            f"[T+{ut-start_ut:.0f}s] ALT={flight.mean_altitude:.0f}m | SURF_ALT={flight.surface_altitude:.0f}m | "\n            f"SPD={flight.speed:.1f}m/s | AP={vessel.orbit.apoapsis_altitude:.0f}m | PE={vessel.orbit.periapsis_altitude:.0f}m | "\n            f"BODY={vessel.orbit.body.name} | FUEL={fuel_percent(vessel):.1f}% | PHASE={phase[\'name\']}"\n        )\n    return log\n\n\ndef wait_for_liftoff(vessel, log):\n    deadline = time.time() + 15.0\n    while time.time() < deadline:\n        if vessel.flight(vessel.surface_reference_frame).surface_altitude > 15.0:\n            return\n        log()\n        time.sleep(0.1)\n    raise RuntimeError(\'Liftoff failure\')\n\n\ndef active_engine_count(vessel):\n    try:\n        return len([e for e in vessel.parts.engines if e.active])\n    except Exception:\n        return 0\n\n\ndef smart_stage(vessel, log, phase, reason, settle=1.5):\n    print(f\'STAGING: {reason}\')\n    vessel.control.throttle = 0.0\n    time.sleep(0.3)\n    vessel.control.activate_next_stage()\n    time.sleep(settle)\n    log(force=True)\n\n\ndef point_to_node(vessel, node):\n    ap = vessel.auto_pilot\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.5)\n\n\ndef execute_node(conn, vessel, node, log, phase, max_duration=900):\n    sc = conn.space_center\n    point_to_node(vessel, node)\n    rem = conn.add_stream(getattr, node, \'remaining_delta_v\')\n    bt = burn_time(vessel, max(node.delta_v, 1.0))\n    start_ut = node.ut - bt / 2.0\n\n    if sc.ut < start_ut - 120:\n        sc.warp_to(start_ut - 25)\n    while sc.ut < start_ut:\n        log()\n        time.sleep(0.1)\n\n    t0 = time.time()\n    no_thrust_cycles = 0\n    vessel.control.throttle = 1.0\n\n    while rem() > 20.0:\n        log()\n        if vessel.thrust < 1.0 and vessel.control.throttle > 0.5:\n            no_thrust_cycles += 1\n        else:\n            no_thrust_cycles = 0\n        if no_thrust_cycles >= 10:\n            smart_stage(vessel, log, phase, \'engine flameout during node burn\')\n            point_to_node(vessel, node)\n            vessel.control.throttle = 1.0\n            no_thrust_cycles = 0\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node burn timeout rem_dv={rem():.2f}\')\n        time.sleep(0.05)\n\n    vessel.control.throttle = 0.25\n    while rem() > 2.0:\n        log()\n        if vessel.thrust < 1.0 and vessel.control.throttle > 0.1:\n            no_thrust_cycles += 1\n        else:\n            no_thrust_cycles = 0\n        if no_thrust_cycles >= 10:\n            smart_stage(vessel, log, phase, \'engine flameout during trim burn\')\n            point_to_node(vessel, node)\n            vessel.control.throttle = 0.25\n            no_thrust_cycles = 0\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node trim timeout rem_dv={rem():.2f}\')\n        time.sleep(0.05)\n\n    vessel.control.throttle = 0.08\n    while rem() > 0.3:\n        log()\n        if time.time() - t0 > max_duration:\n            raise RuntimeError(f\'Node final timeout rem_dv={rem():.2f}\')\n        time.sleep(0.05)\n\n    vessel.control.throttle = 0.0\n    time.sleep(0.3)\n    node.remove()\n\n\ndef required_phase_angle(mu, r1, r2):\n    a = 0.5 * (r1 + r2)\n    t = math.pi * math.sqrt(a ** 3 / mu)\n    target_rate = math.sqrt(mu / r2 ** 3)\n    return (math.pi - target_rate * t) % (2 * math.pi)\n\n\ndef current_phase_angle(vessel, target_body, parent_body):\n    frame = parent_body.non_rotating_reference_frame\n    vp = vessel.position(frame)\n    tp = target_body.position(frame)\n    va = math.atan2(vp[1], vp[0])\n    ta = math.atan2(tp[1], tp[0])\n    return (ta - va) % (2 * math.pi)\n\n\ndef plan_tmi(conn, vessel, mun, base_ut, base_dv):\n    best = None\n    best_score = 1e30\n    grids = [\n        ([-360, -240, -120, -60, 0, 60, 120, 240, 360], [-220, -160, -100, -60, 0, 60, 100, 160, 220]),\n        ([-90, -60, -30, -15, 0, 15, 30, 60, 90], [-60, -40, -20, -10, 0, 10, 20, 40, 60]),\n        ([-20, -10, -5, 0, 5, 10, 20], [-15, -10, -5, 0, 5, 10, 15]),\n    ]\n\n    center_ut = base_ut\n    center_dv = base_dv\n    for time_offsets, dv_offsets in grids:\n        local_best = None\n        local_score = 1e30\n        for dt in time_offsets:\n            for ddv in dv_offsets:\n                node = vessel.control.add_node(center_ut + dt, prograde=center_dv + ddv)\n                try:\n                    nxt = node.orbit.next_orbit\n                    hit = nxt is not None and nxt.body.name == \'Mun\'\n                    closest = node.orbit.distance_at_closest_approach(mun.orbit)\n                    score = closest - (1e9 if hit else 0.0)\n                    if score < local_score:\n                        local_score = score\n                        local_best = {\'ut\': center_ut + dt, \'dv\': center_dv + ddv, \'hit\': hit, \'closest\': closest}\n                finally:\n                    node.remove()\n        if local_best is None:\n            break\n        best = local_best\n        best_score = local_score\n        center_ut = local_best[\'ut\']\n        center_dv = local_best[\'dv\']\n    return best, best_score\n\n\ndef ascent(conn, vessel, log, phase):\n    control = vessel.control\n    ap = vessel.auto_pilot\n    ap.disengage()\n    time.sleep(0.2)\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n\n    phase[\'name\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    wait_for_liftoff(vessel, log)\n\n    dead_engine_cycles = 0\n    lower_stage_dropped = False\n\n    while True:\n        fl = vessel.flight(vessel.surface_reference_frame)\n        alt = fl.mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        q = fl.dynamic_pressure\n\n        if alt < 1000:\n            pitch = 90\n        elif alt < 10000:\n            pitch = 90 - 45 * ((alt - 1000) / 9000.0)\n        elif alt < 45000:\n            pitch = 45 - 35 * ((alt - 10000) / 35000.0)\n        else:\n            pitch = 10\n        pitch = clamp(pitch, 5, 90)\n        ap.target_pitch_and_heading(pitch, 90)\n\n        if q > 30000:\n            control.throttle = 0.45\n        elif q > 20000:\n            control.throttle = 0.65\n        else:\n            control.throttle = 1.0\n\n        if not lower_stage_dropped:\n            if vessel.thrust < 1.0 and control.throttle > 0.5:\n                dead_engine_cycles += 1\n            else:\n                dead_engine_cycles = 0\n            if dead_engine_cycles >= 10:\n                smart_stage(vessel, log, phase, \'lower stage flameout\')\n                control.throttle = 1.0\n                lower_stage_dropped = True\n                dead_engine_cycles = 0\n\n        log()\n        if ap_alt >= TARGET_LKO_AP and alt < 70000:\n            control.throttle = 0.0\n            return\n        if alt > 70000 and ap_alt < TARGET_LKO_AP:\n            raise RuntimeError(f\'Ascent failure ALT={alt:.0f} AP={ap_alt:.0f}\')\n        time.sleep(0.05)\n\n\ndef circularize(conn, vessel, kerbin, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'COAST_TO_AP\'\n    if vessel.orbit.time_to_apoapsis > 120:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_apoapsis - 45)\n    while vessel.orbit.time_to_apoapsis > 12:\n        log()\n        time.sleep(0.1)\n\n    phase[\'name\'] = \'CIRCULARIZATION\'\n    mu = kerbin.gravitational_parameter\n    r = vessel.orbit.apoapsis\n    a1 = vessel.orbit.semi_major_axis\n    dv = vis_viva(mu, r, r) - vis_viva(mu, r, a1)\n    node = control.add_node(sc.ut + vessel.orbit.time_to_apoapsis, prograde=dv)\n    execute_node(conn, vessel, node, log, phase, max_duration=300)\n\n    if vessel.orbit.periapsis_altitude < TARGET_LKO_PE or vessel.orbit.body.name != \'Kerbin\':\n        raise RuntimeError(\n            f\'Circularization failure PE={vessel.orbit.periapsis_altitude:.0f} BODY={vessel.orbit.body.name}\'\n        )\n\n\ndef tmi(conn, vessel, kerbin, mun, log, phase):\n    sc = conn.space_center\n    control = vessel.control\n\n    phase[\'name\'] = \'WAIT_TMI_WINDOW\'\n    mu = kerbin.gravitational_parameter\n    r1 = vessel.orbit.semi_major_axis\n    r2 = mun.orbit.semi_major_axis\n    need = required_phase_angle(mu, r1, r2)\n    rate = math.sqrt(mu / r1 ** 3) - math.sqrt(mu / r2 ** 3)\n\n    while True:\n        cur = current_phase_angle(vessel, mun, kerbin)\n        err = (need - c