00:53:02  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_5.py', 'content': 'import math\nimport time\nimport sys\n\nimport krpc\n\n\nLOG_INTERVAL = 5.0\nTARGET_LKO_AP = 90000.0\nTARGET_LKO_PE = 80000.0\nTARGET_MUN_PERIAPSIS = 30000.0\nTARGET_MUN_APOAPSIS_LIMIT = 500000.0\nPHASE_NAME = \'INIT\'\n\n\nclass MissionContext:\n    def __init__(self, conn):\n        self.conn = conn\n        self.sc = conn.space_center\n        self.kerbin = self.sc.bodies[\'Kerbin\']\n        self.mun = self.sc.bodies[\'Mun\']\n        self.refresh()\n\n    def refresh(self):\n        self.vessel = self.sc.active_vessel\n        self.control = self.vessel.control\n        self.ap = self.vessel.auto_pilot\n        self.surface_flight = self.vessel.flight(self.vessel.surface_reference_frame)\n        self.sc.target_body = self.mun\n\n\ndef clamp(value, low, high):\n    return max(low, min(high, value))\n\n\ndef vec_dot(a, b):\n    return sum(x * y for x, y in zip(a, b))\n\n\ndef vec_cross(a, b):\n    return (\n        a[1] * b[2] - a[2] * b[1],\n        a[2] * b[0] - a[0] * b[2],\n        a[0] * b[1] - a[1] * b[0],\n    )\n\n\ndef unit(v):\n    mag = math.sqrt(v[0] ** 2 + v[1] ** 2 + v[2] ** 2)\n    if mag <= 0.0:\n        return (0.0, 0.0, 0.0)\n    return (v[0] / mag, v[1] / mag, v[2] / mag)\n\n\ndef signed_phase_angle(vessel_pos, target_pos, orbit_normal):\n    vp = unit(vessel_pos)\n    tp = unit(target_pos)\n    n = unit(orbit_normal)\n    d = clamp(vec_dot(vp, tp), -1.0, 1.0)\n    ang = math.acos(d)\n    c = vec_cross(vp, tp)\n    if vec_dot(c, n) < 0:\n        ang = 2.0 * math.pi - ang\n    return ang\n\n\ndef burn_time(vessel, delta_v):\n    thrust = vessel.available_thrust\n    if thrust <= 0.0:\n        thrust = max(vessel.max_thrust, 0.1)\n    isp = max(vessel.specific_impulse * 9.82, 0.1)\n    m0 = vessel.mass\n    mf = m0 / math.exp(delta_v / isp)\n    flow_rate = thrust / isp\n    return max((m0 - mf) / flow_rate, 0.1)\n\n\ndef resources_fraction(ctx):\n    try:\n        res = ctx.vessel.resources\n        names = list(res.names)\n        lf = res.amount(\'LiquidFuel\') if \'LiquidFuel\' in names else 0.0\n        ox = res.amount(\'Oxidizer\') if \'Oxidizer\' in names else 0.0\n        lf_max = res.max(\'LiquidFuel\') if \'LiquidFuel\' in names else 0.0\n        ox_max = res.max(\'Oxidizer\') if \'Oxidizer\' in names else 0.0\n        total = lf + ox\n        total_max = lf_max + ox_max\n        if total_max <= 0.0:\n            return 0.0\n        return 100.0 * total / total_max\n    except Exception:\n        return 0.0\n\n\ndef wait_for_pointing(ctx, timeout=60.0, tolerance=3.0):\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            if ctx.ap.error < tolerance:\n                return True\n        except RuntimeError as exc:\n            if \'Not the active vessel\' in str(exc):\n                ctx.refresh()\n            else:\n                raise\n        time.sleep(0.1)\n    return False\n\n\ndef activate_stage(ctx):\n    ctx.control.activate_next_stage()\n    time.sleep(1.2)\n    ctx.refresh()\n\n\ndef main():\n    global PHASE_NAME\n\n    conn = krpc.connect(name=\'MunMissionAgent\')\n    ctx = MissionContext(conn)\n    sc = ctx.sc\n    ut_stream = conn.add_stream(getattr, sc, \'ut\')\n\n    mission_start_ut = ut_stream()\n    last_log_ut = -1e9\n    last_stage_time = -1e9\n\n    def orbit_body_name():\n        try:\n            return ctx.vessel.orbit.body.name\n        except RuntimeError as exc:\n            if \'Not the active vessel\' in str(exc):\n                ctx.refresh()\n                return ctx.vessel.orbit.body.name\n            return \'UNKNOWN\'\n        except Exception:\n            return \'UNKNOWN\'\n\n    def altitude():\n        return ctx.surface_flight.mean_altitude\n\n    def surface_altitude():\n        return ctx.surface_flight.surface_altitude\n\n    def speed():\n        return ctx.surface_flight.speed\n\n    def apoapsis_altitude():\n        return ctx.vessel.orbit.apoapsis_altitude\n\n    def periapsis_altitude():\n        return ctx.vessel.orbit.periapsis_altitude\n\n    def log_status(force=False):\n        nonlocal last_log_ut\n        now_ut = ut_stream()\n        if force or now_ut - last_log_ut >= LOG_INTERVAL:\n            print(\n                f"[T+{now_ut - mission_start_ut:.0f}s] "\n                f"ALT={altitude():.0f}m | "\n                f"SURF_ALT={surface_altitude():.0f}m | "\n                f"SPD={speed():.1f}m/s | "\n                f"AP={apoapsis_altitude():.0f}m | "\n                f"PE={periapsis_altitude():.0f}m | "\n                f"BODY={orbit_body_name()} | "\n                f"FUEL={resources_fraction(ctx):.1f}% | "\n                f"PHASE={PHASE_NAME}"\n            )\n            sys.stdout.flush()\n            last_log_ut = now_ut\n\n    def maybe_stage():\n        nonlocal last_stage_time\n        now = time.time()\n        if now - last_stage_time < 2.5:\n            return\n        active_engines = [e for e in ctx.vessel.parts.engines if e.active]\n        if not active_engines:\n            activate_stage(ctx)\n            last_stage_time = now\n            return True\n        if ctx.control.throttle > 0.1 and ctx.vessel.available_thrust < 1.0:\n            activate_stage(ctx)\n            last_stage_time = now\n            return True\n        if all((not e.has_fuel) for e in active_engines):\n            activate_stage(ctx)\n            last_stage_time = now\n            return True\n        return False\n\n    def stabilize_after_stage():\n        global PHASE_NAME\n        PHASE_NAME = \'POST_STAGE_STABILIZE\'\n        ctx.refresh()\n        ctx.control.throttle = 0.0\n        ctx.control.rcs = False\n        ctx.ap.engage()\n        try:\n            ctx.ap.target_pitch_and_heading(20.0, 90.0)\n        except Exception:\n            pass\n        wait_for_pointing(ctx, timeout=8.0, tolerance=8.0)\n        time.sleep(0.5)\n        ctx.control.throttle = 0.25\n        time.sleep(1.5)\n        if abs(ctx.surface_flight.sideslip_angle) > math.radians(20.0) if hasattr(ctx.surface_flight, \'sideslip_angle\') else False:\n            ctx.control.throttle = 0.0\n            wait_for_pointing(ctx, timeout=5.0, tolerance=6.0)\n        ctx.control.throttle = 1.0\n\n    def execute_node(node, label):\n        global PHASE_NAME\n        PHASE_NAME = label\n        ctx.refresh()\n        ctx.ap.reference_frame = node.reference_frame\n        ctx.ap.target_direction = (0.0, 1.0, 0.0)\n        ctx.ap.engage()\n        wait_for_pointing(ctx)\n\n        bt = burn_time(ctx.vessel, max(abs(node.delta_v), 1.0))\n        burn_start = node.ut - bt / 2.0\n        if burn_start - ut_stream() > 15.0:\n            sc.warp_to(burn_start - 10.0)\n        while ut_stream() < burn_start:\n            log_status()\n            time.sleep(0.1)\n\n        ctx.control.throttle = 1.0\n        while node.remaining_delta_v > 50.0:\n            log_status()\n            time.sleep(0.05)\n        ctx.control.throttle = 0.3\n        while node.remaining_delta_v > 10.0:\n            log_status()\n            time.sleep(0.05)\n        ctx.control.throttle = 0.1\n        while node.remaining_delta_v > 1.0:\n            log_status()\n            time.sleep(0.05)\n        ctx.control.throttle = 0.0\n        time.sleep(0.5)\n        node.remove()\n        ctx.refresh()\n\n    PHASE_NAME = \'LAUNCH\'\n    ctx.control.throttle = 1.0\n    ctx.control.sas = False\n    ctx.control.rcs = False\n    ctx.ap.engage()\n    ctx.ap.target_pitch_and_heading(90.0, 90.0)\n    time.sleep(1.0)\n    activate_stage(ctx)\n    last_stage_time = time.time()\n    log_status(force=True)\n\n    while True:\n        alt = altitude()\n        apo = apoapsis_altitude()\n\n        if alt < 3000.0:\n            target_pitch = 90.0\n        elif alt < 12000.0:\n            frac = (alt - 3000.0) / 9000.0\n            target_pitch = 90.0 - 35.0 * frac\n        elif alt < 45000.0:\n            frac = (alt - 12000.0) / 33000.0\n            target_pitch = 55.0 - 40.0 * frac\n        else:\n            frac = min((alt - 45000.0) / 25000.0, 1.0)\n            target_pitch = 15.0 - 8.0 * frac\n        ctx.ap.target_pitch_and_heading(max(7.0, target_pitch), 90.0)\n\n        q = 0.0\n        try:\n            q = ctx.surface_flight.dynamic_pressure\n        except Exception:\n            q = 0.0\n\n        if q > 20000.0:\n            ctx.control.throttle = 0.55\n        elif q > 12000.0:\n            ctx.control.throttle = 0.75\n        else:\n            ctx.control.throttle = 1.0\n\n        staged = maybe_stage()\n        if staged:\n            stabilize_after_stage()\n\n        if apo >= TARGET_LKO_AP and alt < 70000.0:\n            ctx.control.throttle = 0.0\n            break\n\n        log_status()\n        time.sleep(0.1)\n\n    PHASE_NAME = \'COAST_TO_AP\'\n    while ctx.vessel.orbit.time_to_apoapsis > 35.0:\n        log_status()\n        time.sleep(0.2)\n\n    mu = ctx.vessel.orbit.body.gravitational_parameter\n    r = ctx.vessel.orbit.apoapsis\n    a1 = ctx.vessel.orbit.semi_major_axis\n    v1 = math.sqrt(mu * (2.0 / r - 1.0 / a1))\n    v2 = math.sqrt(mu / r)\n    circ_dv = max(v2 - v1, 0.0)\n    circ_node = ctx.control.add_node(ut_stream() + ctx.vessel.orbit.time_to_apoapsis, prograde=circ_dv)\n    execute_node(circ_node, \'CIRCULARIZE\')\n    log_status(force=True)\n\n    if ctx.vessel.orbit.body.name != \'Kerbin\' or ctx.vessel.orbit.periapsis_altitude < 75000.0:\n        raise RuntimeError(\n            f"Failed Phase 2 verification: BODY={ctx.vessel.orbit.body.name}, PE={ctx.vessel.orbit.periapsis_altitude:.0f}m"\n        )\n\n    PHASE_NAME = \'WAIT_TMI_WINDOW\'\n    mu_k = ctx.kerbin.gravitational_parameter\n    r_depart = ctx.vessel.orbit.semi_major_axis\n    r_target = ctx.mun.orbit.semi_major_axis\n    a_transfer = 0.5 * (r_depart + r_target)\n    t_transfer = math.pi * math.sqrt(a_transfer ** 3 / mu_k)\n    required_phase = math.pi - math.sqrt(mu_k / r_target ** 3) * t_transfer\n    vessel_rate = math.sqrt(mu_k / r_depart ** 3)\n    target_rate = math.sqrt(mu_k / r_target ** 3)\n    relative_rate = vessel_rate - target_rate\n    frame = ctx.kerbin.non_rotating_reference_frame\n\n    while True:\n        vessel_pos = ctx.vessel.position(frame)\n        vessel_vel = ctx.vessel.velocity(frame)\n        mun_pos = ctx.mun.position(frame)\n        normal = vec_cross(vessel_pos, vessel_vel)\n        current_phase = signed_phase_angle(vessel_pos, mun_pos, normal)\n        phase_error = (required_phase - current_phase) % (2.0 * math.pi)\n        if phase_error < math.radians(2.0):\n            break\n        wait_time = phase_error / relative_rate\n        if wait_time > 180.0:\n            sc.warp_to(ut_stream() + wait_time - 60.0)\n        else:\n            time.sleep(0.5)\n        log_status()\n\n    transfer_dv = math.sqrt(mu_k / r_depart) * (math.sqrt((2.0 * r_target) / (r_depart + r_target)) - 1.0)\n    base_ut = ut_stream() + ctx.vessel.orbit.time_to_apoapsis\n    tmi_node = ctx.control.add_node(base_ut, prograde=transfer_dv)\n\n    best_score = float(\'inf\')\n    best_ut = base_ut\n    best_dv = transfer_dv\n    for dt in [-90, -45, -20, 0, 20, 45, 90]:\n        for ddv in [-40, -20, -10, 0, 10, 20, 40]:\n            tmi_node.ut = base_ut + dt\n            tmi_node.prograde = transfer_dv + ddv\n            try:\n                next_orbit = tmi_node.orbit.next_orbit\n                if next_orbit is not None and next_orbit.body.name == \'Mun\':\n                    peri = next_orbit.periapsis_altitude\n                    if peri != peri:\n                        peri = 1e9\n                    score = abs(peri - TARGET_MUN_PERIAPSIS)\n                else:\n                    score = tmi_node.orbit.distance_at_closest_approach(ctx.mun.orbit)\n            except Exception:\n                score = float(\'inf\')\n            if score < best_score:\n                best_score = score\n                best_ut = tmi_node.ut\n                best_dv = tmi_node.prograde\n\n    tmi_node.ut = best_ut\n    tmi_node.prograde = best_dv\n    execute_node(tmi_node, \'TMI\')\n    log_status(force=True)\n\n    if ctx.vessel.orbit.next_orbit is None or ctx.vessel.orbit.next_orbit.body.name != \'Mun\':\n        raise RuntimeError(\'Failed Phase 3 verification: no Mun encounter predicted after TMI burn.\')\n\n    PHASE_NAME = \'COAST_TO_MUN\'\n    while ctx.vessel.orbit.body.name == \'Kerbin\':\n        t_soi = ctx.vessel.orbit.time_to_soi_change\n        if not math.isnan(t_soi) and t_soi > 240.0:\n            sc.warp_to(ut_stream() + t_soi - 90.0)\n        log_status()\n        time.sleep(0.2)\n\n    PHASE_NAME = \'MUN_APPROACH\'\n    while ctx.vessel.orbit.time_to_periapsis > 90.0:\n        if ctx.vessel.orbit.time_to_periapsis > 240.0:\n            sc.warp_to(ut_stream() + ctx.vessel.orbit.time_to_periapsis - 90.0)\n        log_status()\n        time.sleep(0.2)\n\n    mu_m = ctx.vessel.orbit.body.gravitational_parameter\n    r_p = ctx.vessel.orbit.periapsis\n    a_current = ctx.vessel.orbit.semi_major_axis\n    v_current = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a_current))\n    v_circular = math.sqrt(mu_m / r_p)\n    moi_dv = max(v_current - v_circular, 0.0)\n    moi_node = ctx.control.add_node(ut_stream() + ctx.vessel.orbit.time_to_periapsis, prograde=-moi_dv)\n    execute_node(moi_node, \'MOI\')\n    log_status(force=True)\n\n    if ctx.vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(\'Failed Phase 4 verification: vessel not orbiting Mun after MOI.\')\n\n    if ctx.vessel.orbit.apoapsis_altitude > TARGET_MUN_APOAPSIS_LIMIT:\n        PHASE_NAME = \'MUN_TRIM\'\n        while ctx.vessel.orbit.time_to_periapsis > 30.0:\n            log_status()\n            time.sleep(0.2)\n        r_p = ctx.vessel.orbit.periapsis\n        a1 = ctx.vessel.orbit.semi_major_axis\n        target_ap = ctx.vessel.orbit.body.equatorial_radius + 200000.0\n        a2 = 0.5 * (r_p + target_ap)\n        v1 = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a1))\n        v2 = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a2))\n        trim_node = ctx.control.add_node(ut_stream() + ctx.vessel.orbit.time_to_periapsis, prograde=(v2 - v1))\n        execute_node(trim_node, \'MUN_TRIM\')\n        log_status(force=True)\n\n    if ctx.vessel.orbit.body.name != \'Mun\' or ctx.vessel.orbit.periapsis_altitude < 10000.0 or ctx.vessel.orbit.apoapsis_altitude > TARGET_MUN_APOAPSIS_LIMIT:\n        raise RuntimeError(\n            f"Final orbit invalid: BODY={ctx.vessel.orbit.body.name}, PE={ctx.vessel.orbit.periapsis_altitude:.0f}m, AP={ctx.vessel.orbit.apoapsis_altitude:.0f}m"\n        )\n\n    PHASE_NAME = \'MUN_ORBIT_VERIFY\'\n    ctx.control.throttle = 0.0\n    verify_until = ut_stream() + ctx.vessel.orbit.period\n    while ut_stream() < verify_until:\n        if ctx.vessel.thrust > 0.1:\n            raise RuntimeError(\'Unexpected thrust detected during one-orbit Mun verification.\')\n        log_status()\n        time.sleep(0.5)\n\n    PHASE_NAME = \'MISSION_COMPLETE\'\n    log_status(force=True)\n    print(\'Mission success: stable Mun orbit sustained for one full orbit without thrust.\')\n    sys.stdout.flush()\n\n\nif __name__ == \'__main__\':\n    main()\n'})
