3)\n    rel_rate = vessel_rate - mun_rate\n\n    while True:\n        current_phase = signed_phase(vessel, mun, kerbin)\n        phase_error = (needed_phase - current_phase) % (2.0 * math.pi)\n        if phase_error > math.pi:\n            phase_error -= 2.0 * math.pi\n        log()\n        if abs(phase_error) < math.radians(1.5):\n            break\n        if rel_rate > 0 and abs(phase_error) > math.radians(5):\n            wait_s = abs(phase_error) / rel_rate\n            if wait_s > 120:\n                sc.warp_to(sc.ut + wait_s - 60)\n        time.sleep(0.2)\n\n    phase[\'name\'] = \'PLAN_TMI\'\n    a_transfer = 0.5 * (r_departure + r_target)\n    v_circ = math.sqrt(mu_k / r_departure)\n    v_trans = math.sqrt(mu_k * (2.0 / r_departure - 1.0 / a_transfer))\n    tmi_dv = max(0.0, v_trans - v_circ)\n    base_ut = sc.ut + vessel.orbit.time_to_apoapsis\n\n    best = find_best_mun_node(conn, vessel, mun, base_ut, tmi_dv)\n    if best is None:\n        raise RuntimeError(\'TMI planning failure: unable to evaluate maneuver candidates\')\n\n    node = control.add_node(best[0], prograde=best[1])\n    phase[\'name\'] = \'EXECUTE_TMI\'\n    execute_node(conn, vessel, node, log, phase)\n\n    nxt = vessel.orbit.next_orbit\n    if nxt is None or nxt.body.name != \'Mun\':\n        raise RuntimeError(\'TMI failed: no Mun encounter predicted after planned node execution\')\n\n    # Phase 4: coast and MOI using actual periapsis\n    phase[\'name\'] = \'COAST_TO_MUN\'\n    t_soi = vessel.orbit.time_to_soi_change\n    if not math.isnan(t_soi) and t_soi > 120:\n        sc.warp_to(sc.ut + t_soi - 60)\n    while vessel.orbit.body.name == \'Kerbin\':\n        log()\n        time.sleep(0.2)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f"SOI failure: BODY={vessel.orbit.body.name}")\n\n    phase[\'name\'] = \'PLAN_MOI\'\n    while vessel.orbit.time_to_periapsis > 30:\n        log()\n        time.sleep(0.1)\n\n    mu_m = mun.gravitational_parameter\n    r_peri = vessel.orbit.periapsis\n    a_hyp = vessel.orbit.semi_major_axis\n    v_peri = vis_viva(mu_m, r_peri, a_hyp)\n    r_target_m = mun.equatorial_radius + TARGET_MUN_PE\n    v_circ_m = math.sqrt(mu_m / r_target_m)\n    moi_dv = max(0.0, v_peri - v_circ_m + 10.0)\n\n    node = control.add_node(sc.ut + vessel.orbit.time_to_periapsis, prograde=-moi_dv)\n    phase[\'name\'] = \'MOI\'\n    execute_node(conn, vessel, node, log, phase)\n\n    # cleanup trim if needed\n    if vessel.orbit.body.name == \'Mun\' and (vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP):\n        ap.reference_frame = vessel.orbital_reference_frame\n        ap.target_direction = (0, -1, 0)\n        ap.engage()\n        time.sleep(1.0)\n        control.throttle = 0.15\n        trim_deadline = time.time() + 180\n        while time.time() < trim_deadline:\n            log()\n            if vessel.orbit.periapsis_altitude >= 10000 and vessel.orbit.apoapsis_altitude <= MAX_MUN_AP:\n                break\n            if vessel.orbit.apoapsis_altitude < 120000:\n                control.throttle = 0.05\n            time.sleep(0.05)\n        control.throttle = 0.0\n\n    if vessel.orbit.body.name != \'Mun\' or vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n        raise RuntimeError(\n            f"Post-MOI orbit invalid: BODY={vessel.orbit.body.name} PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}"\n        )\n\n    phase[\'name\'] = \'VERIFY_ONE_ORBIT\'\n    end_ut = sc.ut + vessel.orbit.period\n    while sc.ut < end_ut:\n        control.throttle = 0.0\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            raise RuntimeError(\'Verification failure: left Mun orbit\')\n        if vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n            raise RuntimeError(\n                f"Verification failure: PE={vessel.orbit.periapsis_altitude: