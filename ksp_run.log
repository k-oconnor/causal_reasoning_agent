15:32:00  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_1.py', 'content': '"""\nFlight script — Attempt 1\nMun Orbit Mission — KSP 1.x via kRPC\n\nRocket: 3-stage (2×Reliant booster, Swivel sustainer, Terrier upper)\nMission: Launch → Gravity turn → LKO → TMI → Mun encounter → MOI → Orbit\n"""\n\nimport os\nimport math\nimport time as _time\nimport krpc\n\n# ── Paths (injected by agent) ─────────────────────────────────────────────\nWORKSPACE = r"C:\\Users\\kevin\\OneDrive\\Desktop\\causal_reasoning_agent\\agent_workspace"\nN = 1\nTEL_FILE    = os.path.join(WORKSPACE, f"telemetry_attempt_{N}.txt")\nBURNS_FILE  = os.path.join(WORKSPACE, f"burns_attempt_{N}.txt")\nEVENTS_FILE = os.path.join(WORKSPACE, f"events_attempt_{N}.txt")\n\n# ── Connect ───────────────────────────────────────────────────────────────\nconn   = krpc.connect(name=f"MunMission_Attempt{N}")\nsc     = conn.space_center\nvessel = sc.active_vessel\n\n# ── Body references ──────────────────────────────────────────────────────\nkerbin = sc.bodies["Kerbin"]\nmun    = sc.bodies["Mun"]\nmu_k   = kerbin.gravitational_parameter\nr_k    = kerbin.equatorial_radius\n\n# ── Streams ───────────────────────────────────────────────────────────────\nut_stream   = conn.add_stream(getattr, sc, "ut")\nalt_stream  = conn.add_stream(getattr, vessel.flight(vessel.surface_reference_frame), "mean_altitude")\nspd_stream  = conn.add_stream(getattr, vessel.orbit, "speed")\napo_stream  = conn.add_stream(getattr, vessel.orbit, "apoapsis_altitude")\npe_stream   = conn.add_stream(getattr, vessel.orbit, "periapsis_altitude")\necc_stream  = conn.add_stream(getattr, vessel.orbit, "eccentricity")\nbody_stream = conn.add_stream(lambda: vessel.orbit.body.name)\nfuel_stream = conn.add_stream(lambda: (\n    vessel.resources.amount("LiquidFuel") + vessel.resources.amount("Oxidizer")\n))\nfuel_max_stream = conn.add_stream(lambda: (\n    max(vessel.resources.max("LiquidFuel") + vessel.resources.max("Oxidizer"), 1.0)\n))\n\n# ── Telemetry helpers ────────────────────────────────────────────────────\n\n_last_tel_t = [0.0]\n\ndef write_telemetry(f, phase):\n    """Write one telemetry row every 5 s of game time."""\n    global _last_tel_t\n    ut = ut_stream()\n    if ut - _last_tel_t[0] < 5.0:\n        return\n    _last_tel_t[0] = ut\n    try:\n        fuel_pct = 100.0 * fuel_stream() / fuel_max_stream()\n        met = ut - launch_ut\n        row = (\n            f"[T+{met:.0f}s] ALT={alt_stream():.0f}m "\n            f"SPD={spd_stream():.1f}m/s "\n            f"AP={apo_stream():.0f}m "\n            f"PE={pe_stream():.0f}m "\n            f"ECC={ecc_stream():.4f} "\n            f"BODY={body_stream()} "\n            f"FUEL={fuel_pct:.1f}% "\n            f"PHASE={phase} "\n            f"THROTTLE={vessel.control.throttle:.2f} "\n            f"STAGE={vessel.control.current_stage}\\n"\n        )\n        f.write(row)\n        f.flush()\n    except Exception as exc:\n        f.write(f"[TEL ERROR] {exc}\\n")\n        f.flush()\n\ndef write_event(f, tag, extra=""):\n    """Write a discrete event row."""\n    try:\n        met = ut_stream() - launch_ut\n        f.write(\n            f"[T+{met:.0f}s] EVENT={tag} "\n            f"BODY={body_stream()} "\n            f"ALT={alt_stream():.0f}m "\n            f"{extra}\\n"\n        )\n        f.flush()\n    except Exception as exc:\n        f.write(f"[EVENT ERROR] {exc}\\n")\n        f.flush()\n\ndef write_burn_row(f, node, phase_tag):\n    """Write a burn data row (called every ~0.25s during burns)."""\n    try:\n        ut = ut_stream()\n        row = (\n            f"UT={ut:.2f} "\n            f"RDV={node.remaining_delta_v:.2f} "\n            f"SPD={spd_stream():.2f} "\n            f"THROTTLE={vessel.control.throttle:.2f} "\n            f"STAGE={vessel.control.current_stage} "\n            f"PHASE={phase_tag}\\n"\n        )\n        f.write(row)\n        f.flush()\n    except Exception as exc:\n        f.write(f"[BURN ERROR] {exc}\\n")\n        f.flush()\n\n# ── Burn execution ────────────────────────────────────────────────────────\n\ndef execute_node(node, bf, ef, phase_tag, target_dv=None):\n    """\n    Execute a maneuver node with dual-condition stop:\n    1. remaining_delta_v < 0.5 m/s\n    2. speed_delta >= 0.98 * target_dv (velocity fallback)\n    """\n    ap = vessel.auto_pilot\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0.0, 1.0, 0.0)\n    ap.engage()\n    ap.wait()\n\n    if target_dv is None:\n        target_dv = node.delta_v\n\n    start_speed = spd_stream()\n    rdv_stream = conn.add_stream(getattr, node, "remaining_delta_v")\n\n    # Estimate burn time for lead-in\n    isp    = vessel.specific_impulse * 9.82\n    thrust = max(vessel.available_thrust, 1.0)\n    m0     = vessel.mass\n    mf     = m0 / math.exp(target_dv / isp)\n    bt     = (m0 - mf) / (thrust / isp) if thrust > 0 else 30.0\n    burn_start_ut = node.ut - bt / 2.0\n\n    # Warp to burn start\n    lead = 10.0\n    if ut_stream() < burn_start_ut - lead:\n        sc.warp_to(burn_start_ut - lead)\n        sc.physics_warp_factor = 0\n        sc.rails_warp_factor = 0\n    while ut_stream() < burn_start_ut:\n        _time.sleep(0.05)\n\n    vessel.control.throttle = 1.0\n    write_event(ef, f"BURN_START:{phase_tag}",\n                f"TARGET_DV={target_dv:.1f} START_SPD={start_speed:.1f}")\n\n    # Burn loop\n    while True:\n        write_burn_row(bf, node, phase_tag)\n\n        rdv = rdv_stream()\n        speed_delta = abs(spd_stream() - start_speed)\n\n        # Primary stop\n        if rdv < 0.5:\n            break\n\n        # Velocity fallback\n        if speed_delta >= target_dv * 0.98:\n            break\n\n        # Throttle down near target\n        if rdv < 5.0:\n            vessel.control.throttle = 0.05\n        elif rdv < 20.0:\n            vessel.control.throttle = 0.15\n        elif rdv < 50.0:\n            vessel.control.throttle = 0.35\n\n        _time.sleep(0.05)\n\n    vessel.control.throttle = 0.0\n    _time.sleep(0.2)\n    write_burn_row(bf, node, f"BURN_END:{phase_tag}")\n    write_event(ef, f"BURN_END:{phase_tag}",\n                f"SPD_DELTA={abs(spd_stream()-start_speed):.1f} TARGET_DV={target_dv:.1f}")\n    node.remove()\n\n# ── Vis-viva ──────────────────────────────────────────────────────────────\n\ndef vis_viva(mu, r, a):\n    return math.sqrt(mu * (2.0 / r - 1.0 / a))\n\n# ── Main mission ──────────────────────────────────────────────────────────\n\nwith open(TEL_FILE, "w") as tf, \\\n     open(BURNS_FILE, "w") as bf, \\\n     open(EVENTS_FILE, "w") as ef:\n\n    launch_ut = ut_stream()\n    write_event(ef, "LAUNCH")\n\n    # ── PHASE 1: Launch and gravity turn ──────────────────────────────────\n    write_event(ef, "PHASE_START:ASCENT")\n\n    # Activate stage 1 (2× Reliant)\n    vessel.control.throttle = 1.0\n    _time.sleep(0.5)\n    vessel.control.activate_next_stage()\n    _time.sleep(0.2)\n    write_event(ef, "STAGE_1")\n\n    # Engage autopilot for gravity turn\n    ap = vessel.auto_pilot\n    ap.engage()\n    ap.target_pitch_and_heading(90.0, 90.0)\n\n    max_q = 0.0\n    target_ap = 90_000  # target 90 km apoapsis\n\n    while True:\n        alt = alt_stream()\n        ap_alt = apo_stream()\n        spd = spd_stream()\n        ut = ut_stream()\n\n        write_telemetry(tf, "ASCENT")\n\n        # Gravity turn: pitch from 90° at launch to ~0° by 45 km\n        if alt < 1_000:\n            pitch = 90.0\n        elif alt < 45_000:\n            frac = (alt - 1_000) / (45_000 - 1_000)\n            pitch = 90.0 - 90.0 * frac\n        else:\n            pitch = 0.0\n        ap.target_pitch_and_heading(pitch, 90.0)\n\n        # Throttle back if dynamic pressure > 20 kPa\n        try:\n            q = vessel.flight(vessel.surface_reference_frame).dynamic_pressure\n            if q > max_q:\n                max_q = q\n                write_event(ef, f"MAX_Q", f"Q={q:.0f}Pa")\n            if q > 20_000 and ap_alt < 60_000:\n                vessel.control.throttle = 0.65\n            else:\n                vessel.control.throttle = 1.0\n        except Exception:\n            pass\n\n        # Check if we\'ve reached target apoapsis or are above 70 km\n        if ap_alt >= target_ap:\n            write_event(ef, "APOAPSIS_REACHED", f"AP={ap_alt:.0f}m ALT={alt:.0f}m")\n            break\n\n        if alt > 70_000 and ap_alt < target_ap:\n            # Above 70 km but AP too low — keep burning until AP target\n            write_event(ef, "ABOVE_70KM_AP_LOW", f"AP={ap_alt:.0f}m ALT={alt:.0f}m")\n            # Burn until AP target reached\n            while apo_stream() < target_ap:\n                write_telemetry(tf, "ASCENT_BEYOND_70KM")\n                _time.sleep(0.5)\n            break\n\n        _time.sleep(0.1)\n\n    # Cut throttle\n    vessel.control.throttle = 0.0\n    write_event(ef, "ENGINE_CUT", f"AP={apo_stream():.0f}m ALT={alt_stream():.0f}m")\n\n    # ── Coast to apoapsis ────────────────────────────────────────────────\n    write_event(ef, "PHASE_START:COAST_TO_APOAPSIS")\n\n    # Coast until time to apoapsis < 30s\n    while vessel.orbit.time_to_apoapsis > 30.0:\n        write_telemetry(tf, "COAST_TO_AP")\n        tta = vessel.orbit.time_to_apoapsis\n        if tta > 120.0:\n            sc.rails_warp_factor = 5\n        elif tta > 60.0:\n            sc.rails_warp_factor = 2\n        else:\n            sc.rails_warp_factor = 0\n        _time.sleep(1.0)\n\n    sc.rails_warp_factor = 0\n    sc.physics_warp_factor = 0\n    write_event(ef, "APOAPSIS_COAST_END", f"TTA={vessel.orbit.time_to_apoapsis:.1f}s")\n\n    # ── PHASE 2: Circularization ─────────────────────────────────────────\n    write_event(ef, "PHASE_START:CIRCULARIZATION")\n\n    # Compute circularization dV at apoapsis\n    r_ap = vessel.orbit.apoapsis  # distance from centre\n    a_current = vessel.orbit.semi_major_axis\n    v_current = vis_viva(mu_k, r_ap, a_current)\n    v_circular = math.sqrt(mu_k / r_ap)\n    circ_dv = v_circular - v_current\n\n    write_event(ef, "CIRC_DV_COMPUTED", f"dV={circ_dv:.1f}m/s")\n\n    if circ_dv > 5.0:\n        node = vessel.control.add_node(\n            ut_stream() + vessel.orbit.time_to_apoapsis,\n            prograde=circ_dv\n        )\n        execute_node(node, bf, ef, "CIRCULARIZE", target_dv=circ_dv)\n    else:\n        write_event(ef, "CIRC_SKIPPED", f"dV={circ_dv:.1f}m/s too small")\n\n    # Verify LKO\n    pe = pe_stream()\n    ap = apo_stream()\n    body = body_stream()\n    write_event(ef, "LKO_CHECK", f"PE={pe:.0f}m AP={ap:.0f}m BODY={body}")\n\n    if pe < 75_000:\n        # Need another circularization burn\n        write_event(ef, "LKO_NEEDS_RAISE", f"PE={pe:.0f}m < 75km")\n        r_current = vessel.orbit.apoapsis\n        a_current = vessel.orbit.semi_major_axis\n        a_target = r_current  # circular at current AP\n        v_current = vis_viva(mu_k, r_current, a_current)\n        v_target = math.sqrt(mu_k / r_current)\n        raise_dv = v_target - v_current\n        if raise_dv > 5.0:\n            node = vessel.control.add_node(\n                ut_stream() + vessel.orbit.time_to_apoapsis,\n                prograde=raise_dv\n            )\n            execute_node(node, bf, ef, "CIRCULARIZE_RAISE", target_dv=raise_dv)\n\n    write_event(ef, "LKO_CONFIRMED",\n                f"PE={pe_stream():.0f}m AP={apo_stream():.0f}m BODY={body_stream()}")\n\n    # ── Stage to stage 3 (Terrier) if not already ─────────────────────────\n    if vessel.control.current_stage > 0:\n        write_event(ef, "STAGING_TO_STAGE3")\n        vessel.control.activate_next_stage()\n        _time.sleep(1.0)\n        write_event(ef, f"STAGE_{vessel.control.current_stage}")\n\n    # ── PHASE 3: Trans-Mun Injection ──────────────────────────────────────\n    write_event(ef, "PHASE_START:TMI")\n\n    # Compute Hohmann transfer from LKO to Mun orbit\n    r_lko = vessel.orbit.semi_major_axis\n    r_mun = mun.orbit.semi_major_axis\n\n    a_trans = 0.5 * (r_lko + r_mun)\n    v_lko = math.sqrt(mu_k / r_lko)\n    v_trans = math.sqrt(mu_k * (2.0 / r_lko - 1.0 / a_trans))\n    tmi_dv = v_trans - v_lko\n\n    write_event(ef, "TMI_DV_COMPUTED", f"dV={tmi_dv:.1f}m/s")\n\n    # Place node at next apoapsis\n    node = vessel.control.add_node(\n        ut_stream() + vessel.orbit.time_to_apoapsis,\n        prograde=tmi_dv\n    )\n\n    # Refine: sweep small perturbations for best Mun encounter\n    best_score = float("inf")\n    best_dv = tmi_dv\n    best_dt = 0.0\n\n    for dt in range(-120, 121, 30):\n        for ddv in range(-80, 81, 20):\n            node.ut = ut_stream() + vessel.orbit.time_to_apoapsis + dt\n            node.prograde = tmi_dv + ddv\n            try:\n                nxt = node.orbit.next_orbit\n                if nxt and nxt.body.name == "Mun":\n                    score = abs(nxt.periapsis_altitude - 30_000)\n                else:\n                    score = vessel.orbit.distance_at_closest_approach(mun.orbit)\n            except Exception:\n                score = float("inf")\n            if score < best_score:\n                best_score, best_dv, best_dt = score, tmi_dv + ddv, dt\n\n    node.ut = ut_stream() + vessel.orbit.time_to_apoapsis + best_dt\n    node.prograde = best_dv\n\n    write_event(ef, "TMI_NODE_REFINED",\n                f"dV={best_dv:.1f}m/s dt={best_dt:.1f}s score={best_score:.0f}m")\n\n    # Execute TMI burn\n    execute_node(node, bf, ef, "TMI", target_dv=best_dv)\n\n    # Check for Mun encounter\n    _time.sleep(1.0)\n    if vessel.orbit.next_orbit and vessel.orbit.next_orbit.body.name == "Mun":\n        write_event(ef, "MUN_ENCOUNTER_CONFIRMED",\n                    f"PE={vessel.orbit.next_orbit.periapsis_altitude:.0f}m")\n    else:\n        write_event(ef, "MUN_ENCOUNTER_FAILED",\n                    f"next_body={vessel.orbit.next_orbit.body.name if vessel.orbit.next_orbit else \'None\'}")\n        # Try a correction burn\n        write_event(ef, "ATTEMPTING_CORRECTION_BURN")\n        best = {"score": float("inf"), "dv": (0.0, 0.0)}\n        t_correct = ut_stream() + 0.5 * vessel.orbit.period\n        for dp in range(-50, 51, 10):\n            for dn in range(-50, 51, 10):\n                node2 = vessel.control.add_node(t_correct, prograde=dp, normal=dn)\n                try:\n                    sep = vessel.orbit.distance_at_closest_approach(mun.orbit)\n                except Exception:\n                    sep = float("inf")\n                if sep < best["score"]:\n                    best = {"score": sep, "dv": (dp, dn)}\n                node2.remove()\n        if best["score"] < float("inf"):\n            node2 = vessel.control.add_node(t_correct,\n                                            prograde=best["dv"][0],\n                                            normal=best["dv"][1])\n            execute_node(node2, bf, ef, "TMI_CORRECTION",\n                         target_dv=math.sqrt(best["dv"][0]**2 + best["dv"][1]**2))\n\n    # ── Coast to Mun ──────────────────────────────────────────────────────\n    write_event(ef, "PHASE_START:COAST_TO_MUN")\n\n    # Warp until SOI change is imminent\n    while True:\n        write_telemetry(tf, "COAST_TO_MUN")\n        try:\n            t_soi = vessel.orbit.time_to_soi_change\n        except Exception:\n            t_soi = float("nan")\n\n        if math.isnan(t_soi):\n            # No SOI change predicted — may have already happened or missed\n            if body_stream() == "Mun":\n                write_event(ef, "ALREADY_IN_MUN_SOI")\n                break\n            write_event(ef, "NO_SOI_CHANGE_PREDICTED")\n            _time.sleep(5.0)\n            continue\n\n        if t_soi < 30.0:\n            sc.rails_warp_factor = 0\n            sc.physics_warp_factor = 0\n            _time.sleep(1.0)\n            # Wait for SOI change\n            while body_stream() != "Mun":\n                write_telemetry(tf, "WAITING_SOI_CHANGE")\n                _time.sleep(0.5)\n            write_event(ef, "SOI_CHANGE:Mun")\n            break\n\n        if t_soi > 120.0:\n            sc.rails_warp_factor = 5\n        elif t_soi > 60.0:\n            sc.rails_warp_factor = 2\n        _time.sleep(1.0)\n\n    # ── PHASE 4: Mun Orbit Insertion ──────────────────────────────────────\n    write_event(ef, "PHASE_START:MOI")\n\n    # Coast to Mun periapsis\n    while vessel.orbit.time_to_periapsis > 60.0:\n        write_telemetry(tf, "MOI_APPROACH")\n        ttp = vessel.orbit.time_to_periapsis\n        if ttp > 300.0:\n            sc.rails_warp_factor = 5\n        elif ttp > 120.0:\n            sc.rails_warp_factor = 2\n        else:\n            sc.rails_warp_factor = 0\n        _time.sleep(1.0)\n\n    sc.rails_warp_factor = 0\n    sc.physics_warp_factor = 0\n\n    # Compute MOI burn at periapsis\n    mu_mun = mun.gravitational_parameter\n    r_mun_eq = mun.equatorial_radius\n    r_peri_mun = vessel.orbit.periapsis  # distance from Mun centre\n    a_hyper = vessel.orbit.semi_major_axis\n    target_pe_alt = 30_000  # target 30 km periapsis\n    r_target = r_mun_eq + target_pe_alt\n\n    v_hyper = vis_viva(mu_mun, r_peri_mun, a_hyper)\n    v_circ_target = math.sqrt(mu_mun / r_target)\n    # We want to end up in an elliptical orbit with PE=target_pe, AP=something reasonable\n    a_target = (r_peri_mun + r_target) / 2.0\n    v_target = math.sqrt(mu_mun * (2.0 / r_peri_mun - 1.0 / a_target))\n    moi_dv = v_hyper - v_target\n\n    write_event(ef, "MOI_DV_COMPUTED", f"dV={moi_dv:.1f}m/s")\n\n    if moi_dv > 5.0:\n        node = vessel.control.add_node(\n            ut_stream() + vessel.orbit.time_to_periapsis,\n            prograde=-moi_dv  # retrograde\n        )\n        execute_node(node, bf, ef, "MOI", target_dv=moi_dv)\n    else:\n        write_event(ef, "MOI_SKIPPED", f"dV={moi_dv:.1f}m/s too small")\n\n    # Verify Mun orbit\n    _time.sleep(1.0)\n    final_pe = pe_stream()\n    final_ap = apo_stream()\n    final_body = body_stream()\n    final_ecc = ecc_stream()\n\n    write_event(ef, "MOI_COMPLETE",\n                f"PE={final_pe:.0f}m AP={final_ap:.0f}m BODY={final_body} ECC={final_ecc:.4f}")\n\n    # ── Orbit check ──────────────────────────────────────────────────────\n    if (final_body == "Mun" and final_pe >= 10_000 and final_ap <= 500_000):\n        write_event(ef, "ORBIT_CONFIRMED",\n                    f"PE={final_pe:.0f}m AP={final_ap:.0f}m ECC={final_ecc:.4f}")\n        # Coast for one full orbit to confirm stability\n        write_event(ef, "PHASE_START:ORBIT_COAST")\n        orbit_period = vessel.orbit.period\n        coast_end = ut_stream() + orbit_period\n        while ut_stream() < coast_end:\n            write_telemetry(tf, "ORBIT_COAST")\n            vessel.control.throttle = 0.0\n            _time.sleep(5.0)\n        write_event(ef, "MISSION_SUCCESS",\n                    f"One full orbit sustained. PE={pe_stream():.0f}m AP={apo_stream():.0f}m")\n    else:\n        write_event(ef, "ORBIT_FAILED",\n                    f"PE={final_pe:.0f}m AP={final_ap:.0f}m BODY={final_body}")\n\n    write_event(ef, "MISSION_END")\n'})
