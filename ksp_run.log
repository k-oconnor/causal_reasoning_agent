02:03:30  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_4.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTELEMETRY_INTERVAL = 5.0\nTARGET_AP = 90000.0\nTARGET_PE = 80000.0\nTARGET_MUN_PE = 30000.0\nMAX_MUN_AP = 500000.0\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef fuel_percent(vessel):\n    try:\n        r = vessel.resources\n        cur = r.amount(\'LiquidFuel\') + r.amount(\'Oxidizer\')\n        maxv = r.max(\'LiquidFuel\') + r.max(\'Oxidizer\')\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef logger(conn, vessel, phase):\n    start_ut = conn.space_center.ut\n    last_ut = {\'v\': -1e9}\n\n    def log(force=False):\n        ut = conn.space_center.ut\n        if not force and ut - last_ut[\'v\'] < TELEMETRY_INTERVAL:\n            return\n        last_ut[\'v\'] = ut\n        fl = vessel.flight()\n        print(\n            f"[T+{ut-start_ut:.0f}s] ALT={fl.mean_altitude:.0f}m | SURF_ALT={fl.surface_altitude:.0f}m | "\n            f"SPD={fl.speed:.1f}m/s | AP={vessel.orbit.apoapsis_altitude:.0f}m | PE={vessel.orbit.periapsis_altitude:.0f}m | "\n            f"BODY={vessel.orbit.body.name} | FUEL={fuel_percent(vessel):.1f}% | PHASE={phase[\'name\']}"\n        )\n    return log\n\n\ndef wait_for_liftoff(vessel, log):\n    end = time.time() + 12.0\n    while time.time() < end:\n        log()\n        if vessel.flight().surface_altitude > 20.0:\n            return\n        time.sleep(0.1)\n    raise RuntimeError(f"Liftoff failure: ALT={vessel.flight().mean_altitude:.0f} SPD={vessel.flight().speed:.1f}")\n\n\ndef orient_surface(ap, pitch, heading=90.0):\n    ap.reference_frame = ap._client.space_center.active_vessel.surface_reference_frame\n    ap.target_pitch_and_heading(pitch, heading)\n\n\ndef phase_angle(vessel, mun, frame):\n    vp = vessel.position(frame)\n    mp = mun.position(frame)\n    return (math.atan2(mp[1], mp[0]) - math.atan2(vp[1], vp[0])) % (2 * math.pi)\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    kerbin = sc.bodies[\'Kerbin\']\n    mun = sc.bodies[\'Mun\']\n    control = vessel.control\n    ap = vessel.auto_pilot\n\n    phase = {\'name\': \'PRELAUNCH\'}\n    log = logger(conn, vessel, phase)\n\n    control.sas = False\n    control.rcs = False\n    control.throttle = 0.0\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n    time.sleep(1.0)\n\n    # Launch and closed-loop ascent\n    phase[\'name\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    wait_for_liftoff(vessel, log)\n\n    staged = False\n    while True:\n        fl = vessel.flight()\n        alt = fl.mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        pe_alt = vessel.orbit.periapsis_altitude\n        q = fl.dynamic_pressure\n\n        # Closed-loop pitch schedule based on apoapsis growth and altitude.\n        if alt < 1500:\n            pitch = 90\n        elif alt < 10000:\n            pitch = 90 - 45 * ((alt - 1500) / 8500.0)\n        elif alt < 45000:\n            pitch = 45 - 35 * ((alt - 10000) / 35000.0)\n        else:\n            pitch = 10\n        pitch = clamp(pitch, 5, 90)\n        ap.target_pitch_and_heading(pitch, 90)\n\n        if q > 30000:\n            control.throttle = 0.45\n        elif q > 20000:\n            control.throttle = 0.65\n        else:\n            control.throttle = 1.0\n\n        # Stage when first stage is effectively done.\n        if not staged and vessel.available_thrust < 10:\n            control.activate_next_stage()\n            staged = True\n            time.sleep(1.5)\n            control.throttle = 1.0\n\n        log()\n\n        # End ascent when apoapsis target reached but before exiting atmo too early.\n        if ap_alt >= TARGET_AP and alt < 70000:\n            break\n        if fl.surface_altitude < 0:\n            raise RuntimeError(\'Ascent failure: terrain impact\')\n        time.sleep(0.05)\n\n    control.throttle = 0.0\n\n    # Coast to near apoapsis\n    phase[\'name\'] = \'COAST_TO_AP\'\n    if vessel.orbit.time_to_apoapsis > 90:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_apoapsis - 35)\n    while vessel.orbit.time_to_apoapsis > 8:\n        log()\n        time.sleep(0.1)\n\n    # Closed-loop circularization: burn prograde until PE >= target.\n    phase[\'name\'] = \'CIRCULARIZATION\'\n    ap.reference_frame = vessel.orbital_reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.0)\n    control.throttle = 1.0\n    while vessel.orbit.periapsis_altitude < TARGET_PE:\n        pe = vessel.orbit.periapsis_altitude\n        if pe > 60000:\n            control.throttle = 0.35\n        if pe > 73000:\n            control.throttle = 0.12\n        log()\n        time.sleep(0.05)\n    control.throttle = 0.0\n    time.sleep(1.0)\n\n    if vessel.orbit.periapsis_altitude < 75000 or vessel.orbit.body.name != \'Kerbin\':\n        raise RuntimeError(f"Failed circularization: PE={vessel.orbit.periapsis_altitude:.0f} BODY={vessel.orbit.body.name}")\n\n    # Wait for Mun transfer window by phase angle\n    phase[\'name\'] = \'WAIT_TMI_WINDOW\'\n    frame = kerbin.non_rotating_reference_frame\n    target_phase = math.radians(110)\n    while True:\n        cur = phase_angle(vessel, mun, frame)\n        err = abs((cur - target_phase + math.pi) % (2*math.pi) - math.pi)\n        log()\n        if err < math.radians(2.0):\n            break\n        time.sleep(0.5)\n\n    # Closed-loop TMI: burn prograde until encounter appears.\n    phase[\'name\'] = \'TMI\'\n    ap.reference_frame = vessel.orbital_reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.0)\n    control.throttle = 1.0\n    start_ut = sc.ut\n    while True:\n        nxt = vessel.orbit.next_orbit\n        log()\n        if nxt is not None and nxt.body.name == \'Mun\':\n            break\n        if sc.ut - start_ut > 900:\n            control.throttle = 0.0\n            raise RuntimeError(\'TMI failed: no Mun encounter appeared during prograde burn\')\n        time.sleep(0.05)\n    control.throttle = 0.0\n\n    # Coast to Mun SOI\n    phase[\'name\'] = \'COAST_TO_MUN\'\n    t_soi = vessel.orbit.time_to_soi_change\n    if not math.isnan(t_soi) and t_soi > 90:\n        sc.warp_to(sc.ut + t_soi - 45)\n    while vessel.orbit.body.name == \'Kerbin\':\n        log()\n        time.sleep(0.2)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f"SOI failure: BODY={vessel.orbit.body.name}")\n\n    # Closed-loop MOI: burn retrograde at periapsis until target orbit achieved.\n    phase[\'name\'] = \'MOI\'\n    if vessel.orbit.time_to_periapsis > 90:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_periapsis - 25)\n    while vessel.orbit.time_to_periapsis > 6:\n        log()\n        time.sleep(0.1)\n\n    ap.reference_frame = vessel.orbital_reference_frame\n    ap.target_direction = (0, -1, 0)\n    ap.engage()\n    time.sleep(1.0)\n    control.throttle = 1.0\n    while True:\n        pe = vessel.orbit.periapsis_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        ecc = vessel.orbit.eccentricity\n        log()\n        if pe >= 10000 and ap_alt <= MAX_MUN_AP and ecc < 0.9:\n            break\n        if ap_alt < 200000:\n            control.throttle = 0.35\n        if ap_alt < 80000:\n            control.throttle = 0.12\n        time.sleep(0.05)\n    control.throttle = 0.0\n\n    if vessel.orbit.body.name != \'Mun\' or vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n        raise RuntimeError(\n            f"Post-MOI orbit invalid: BODY={vessel.orbit.body.name} PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}"\n        )\n\n    # Verify one orbit without thrust\n    phase[\'name\'] = \'VERIFY_ONE_ORBIT\'\n    end_ut = sc.ut + vessel.orbit.period\n    while sc.ut < end_ut:\n        control.throttle = 0.0\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            raise RuntimeError(\'Verification failure: left Mun orbit\')\n        if vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n            raise RuntimeError(\n                f"Verification failure: PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}"\n            )\n        time.sleep(0.5)\n\n    phase[\'name\'] = \'MISSION_SUCCESS\'\n    log(force=True)\n    print(\'MISSION SUCCESS: stable Mun orbit sustained for one full orbit.\')\n\n\nif __name__ == \'__main__\':\n    try:\n        main()\n    except Exception as exc:\n        print(\'MISSION FAILURE\')\n        print(str(exc))\n        traceback.print_exc()\n        raise\n'})
