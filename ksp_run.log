00:10:26  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_1.py', 'content': 'import math\nimport time\nimport sys\n\nimport krpc\n\n\nLOG_INTERVAL = 5.0\nTARGET_LKO_AP = 90000.0\nTARGET_LKO_PE = 80000.0\nTARGET_MUN_PERIAPSIS = 30000.0\nMAX_MUN_APOAPSIS = 500000.0\nPHASE_NAME = \'INIT\'\n\n\ndef clamp(value, low, high):\n    return max(low, min(high, value))\n\n\ndef vec_mag(v):\n    return math.sqrt(v[0] ** 2 + v[1] ** 2 + v[2] ** 2 + v[3] ** 2) if len(v) == 4 else math.sqrt(v[0] ** 2 + v[1] ** 2 + v[2] ** 2)\n\n\ndef vec_dot(a, b):\n    return sum(x * y for x, y in zip(a, b))\n\n\ndef vec_cross(a, b):\n    return (\n        a[1] * b[2] - a[2] * b[1],\n        a[2] * b[0] - a[0] * b[2],\n        a[0] * b[1] - a[1] * b[0],\n    )\n\n\ndef unit(v):\n    m = math.sqrt(v[0] ** 2 + v[1] ** 2 + v[2] ** 2)\n    if m == 0:\n        return (0.0, 0.0, 0.0)\n    return (v[0] / m, v[1] / m, v[2] / m)\n\n\ndef signed_phase_angle(vessel_pos, target_pos, orbit_normal):\n    vp = unit(vessel_pos)\n    tp = unit(target_pos)\n    n = unit(orbit_normal)\n    dot = clamp(vec_dot(vp, tp), -1.0, 1.0)\n    ang = math.acos(dot)\n    cross = vec_cross(vp, tp)\n    if vec_dot(cross, n) < 0:\n        ang = 2.0 * math.pi - ang\n    return ang\n\n\ndef burn_time(vessel, delta_v):\n    thrust = vessel.available_thrust\n    if thrust <= 0.0:\n        thrust = max(vessel.max_thrust, 0.1)\n    isp = max(vessel.specific_impulse * 9.82, 0.1)\n    m0 = vessel.mass\n    mf = m0 / math.exp(delta_v / isp)\n    flow_rate = thrust / isp\n    return max((m0 - mf) / flow_rate, 0.1)\n\n\ndef resources_fraction(vessel):\n    res = vessel.resources\n    try:\n        names = list(res.names)\n    except Exception:\n        names = []\n    lf_max = res.max(\'LiquidFuel\') if \'LiquidFuel\' in names else 0.0\n    ox_max = res.max(\'Oxidizer\') if \'Oxidizer\' in names else 0.0\n    lf = res.amount(\'LiquidFuel\') if \'LiquidFuel\' in names else 0.0\n    ox = res.amount(\'Oxidizer\') if \'Oxidizer\' in names else 0.0\n    total = lf + ox\n    total_max = lf_max + ox_max\n    if total_max <= 0:\n        return 0.0\n    return 100.0 * total / total_max\n\n\ndef stage_if_needed(vessel, last_stage_wallclock):\n    now = time.time()\n    if now - last_stage_wallclock < 2.0:\n        return last_stage_wallclock\n    active_engines = [e for e in vessel.parts.engines if e.active]\n    if not active_engines:\n        vessel.control.activate_next_stage()\n        return now\n    try:\n        if vessel.available_thrust < 1.0 and vessel.control.throttle > 0.1:\n            vessel.control.activate_next_stage()\n            return now\n    except Exception:\n        pass\n    no_fuel = True\n    for eng in active_engines:\n        try:\n            if eng.has_fuel:\n                no_fuel = False\n                break\n        except Exception:\n            no_fuel = False\n            break\n    if no_fuel:\n        vessel.control.activate_next_stage()\n        return now\n    return last_stage_wallclock\n\n\ndef wait_for_pointing(ap, timeout=60.0):\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            if ap.error < 3.0:\n                return\n        except Exception:\n            pass\n        time.sleep(0.1)\n\n\ndef connect():\n    return krpc.connect(name=\'MunMissionAgent\')\n\n\ndef main():\n    global PHASE_NAME\n\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    mun = sc.bodies[\'Mun\']\n    kerbin = sc.bodies[\'Kerbin\']\n    sc.target_body = mun\n\n    control = vessel.control\n    ap = vessel.auto_pilot\n    surface_flight = vessel.flight(vessel.surface_reference_frame)\n\n    ut_stream = conn.add_stream(getattr, sc, \'ut\')\n    alt_stream = conn.add_stream(getattr, surface_flight, \'mean_altitude\')\n    surf_alt_stream = conn.add_stream(getattr, surface_flight, \'surface_altitude\')\n    speed_stream = conn.add_stream(getattr, surface_flight, \'speed\')\n    ap_stream = conn.add_stream(getattr, vessel.orbit, \'apoapsis_altitude\')\n    pe_stream = conn.add_stream(getattr, vessel.orbit, \'periapsis_altitude\')\n    body_stream = conn.add_stream(lambda: vessel.orbit.body.name)\n\n    mission_start_ut = ut_stream()\n    last_log_ut = -1e9\n    last_stage_wallclock = 0.0\n\n    def log_status():\n        nonlocal last_log_ut\n        now_ut = ut_stream()\n        if now_ut - last_log_ut >= LOG_INTERVAL:\n            print(\n                f"[T+{now_ut - mission_start_ut:.0f}s] "\n                f"ALT={alt_stream():.0f}m | "\n                f"SURF_ALT={surf_alt_stream():.0f}m | "\n                f"SPD={speed_stream():.1f}m/s | "\n                f"AP={ap_stream():.0f}m | "\n                f"PE={pe_stream():.0f}m | "\n                f"BODY={body_stream()} | "\n                f"FUEL={resources_fraction(vessel):.1f}% | "\n                f"PHASE={PHASE_NAME}"\n            )\n            sys.stdout.flush()\n            last_log_ut = now_ut\n\n    def execute_node(node, phase_label):\n        global PHASE_NAME\n        PHASE_NAME = phase_label\n        remaining_dv = conn.add_stream(getattr, node, \'remaining_delta_v\')\n        ap.reference_frame = node.reference_frame\n        ap.target_direction = (0.0, 1.0, 0.0)\n        ap.engage()\n        wait_for_pointing(ap)\n\n        bt = burn_time(vessel, max(node.delta_v, 1.0))\n        burn_start_ut = node.ut - bt / 2.0\n        lead_time = 10.0\n        if burn_start_ut - ut_stream() > lead_time:\n            sc.warp_to(burn_start_ut - lead_time)\n        while ut_stream() < burn_start_ut:\n            log_status()\n            time.sleep(0.1)\n\n        control.throttle = 1.0\n        while remaining_dv() > 50.0:\n            log_status()\n            time.sleep(0.05)\n        control.throttle = 0.35\n        while remaining_dv() > 10.0:\n            log_status()\n            time.sleep(0.05)\n        control.throttle = 0.12\n        while remaining_dv() > 1.0:\n            log_status()\n            time.sleep(0.05)\n        control.throttle = 0.0\n        time.sleep(0.5)\n        node.remove()\n\n    # Phase 1 — Launch and gravity turn\n    PHASE_NAME = \'LAUNCH\'\n    control.throttle = 1.0\n    control.sas = False\n    control.rcs = False\n    ap.engage()\n    ap.target_pitch_and_heading(90.0, 90.0)\n    time.sleep(1.0)\n    control.activate_next_stage()\n    last_stage_wallclock = time.time()\n\n    while True:\n        alt = alt_stream()\n        apo = ap_stream()\n\n        if alt < 1000.0:\n            target_pitch = 90.0\n        elif alt < 10000.0:\n            frac = (alt - 1000.0) / 9000.0\n            target_pitch = 90.0 - 45.0 * frac\n        elif alt < 45000.0:\n            frac = (alt - 10000.0) / 35000.0\n            target_pitch = 45.0 - 35.0 * frac\n        else:\n            frac = min((alt - 45000.0) / 25000.0, 1.0)\n            target_pitch = 10.0 - 5.0 * frac\n        target_pitch = max(5.0, target_pitch)\n        ap.target_pitch_and_heading(target_pitch, 90.0)\n\n        try:\n            q = surface_flight.dynamic_pressure\n        except Exception:\n            q = 0.0\n        if q > 25000.0:\n            control.throttle = 0.60\n        elif q > 15000.0:\n            control.throttle = 0.80\n        else:\n            control.throttle = 1.0\n\n        last_stage_wallclock = stage_if_needed(vessel, last_stage_wallclock)\n\n        if apo >= TARGET_LKO_AP and alt < 70000.0:\n            control.throttle = 0.0\n            break\n\n        log_status()\n        time.sleep(0.1)\n\n    # Phase 2 — Circularization burn\n    PHASE_NAME = \'COAST_TO_AP\'\n    while vessel.orbit.time_to_apoapsis > 40.0:\n        log_status()\n        time.sleep(0.2)\n\n    mu = vessel.orbit.body.gravitational_parameter\n    r = vessel.orbit.apoapsis\n    a1 = vessel.orbit.semi_major_axis\n    a2 = r\n    v1 = math.sqrt(mu * (2.0 / r - 1.0 / a1))\n    v2 = math.sqrt(mu * (2.0 / r - 1.0 / a2))\n    circularization_dv = max(v2 - v1, 0.0)\n    circularization_node = control.add_node(ut_stream() + vessel.orbit.time_to_apoapsis, prograde=circularization_dv)\n    execute_node(circularization_node, \'CIRCULARIZE\')\n\n    if vessel.orbit.body.name != \'Kerbin\' or vessel.orbit.periapsis_altitude < 75000.0:\n        raise RuntimeError(\'Failed Phase 2 verification: periapsis < 75 km or not orbiting Kerbin.\')\n\n    # Phase 3 — Wait for TMI window using phase angle\n    PHASE_NAME = \'WAIT_TMI_WINDOW\'\n    mu_k = kerbin.gravitational_parameter\n    r_depart = kerbin.equatorial_radius + 90000.0\n    r_target = mun.orbit.semi_major_axis\n    a_transfer = 0.5 * (r_depart + r_target)\n    t_transfer = math.pi * math.sqrt(a_transfer ** 3 / mu_k)\n    target_rate = math.sqrt(mu_k / r_target ** 3)\n    vessel_rate = math.sqrt(mu_k / r_depart ** 3)\n    required_phase = math.pi - target_rate * t_transfer\n\n    frame = kerbin.non_rotating_reference_frame\n    while True:\n        vessel_pos = vessel.position(frame)\n        vessel_vel = vessel.velocity(frame)\n        mun_pos = mun.position(frame)\n        orbit_normal = vec_cross(vessel_pos, vessel_vel)\n        current_phase = signed_phase_angle(vessel_pos, mun_pos, orbit_normal)\n        phase_error = (required_phase - current_phase) % (2.0 * math.pi)\n\n        if phase_error < math.radians(1.5):\n            break\n\n        relative_rate = vessel_rate - target_rate\n        wait_time = phase_error / relative_rate\n        if wait_time > 120.0:\n            sc.warp_to(ut_stream() + wait_time - 60.0)\n        else:\n            time.sleep(0.5)\n        log_status()\n\n    transfer_dv = math.sqrt(mu_k / r_depart) * (math.sqrt((2.0 * r_target) / (r_depart + r_target)) - 1.0)\n    node_ut_base = ut_stream() + vessel.orbit.time_to_apoapsis\n    tmi_node = control.add_node(node_ut_base, prograde=transfer_dv)\n\n    best_score = float(\'inf\')\n    best_ut = node_ut_base\n    best_dv = transfer_dv\n    for dt in [-120, -60, -30, 0, 30, 60, 120]:\n        for ddv in [-60, -30, -15, 0, 15, 30, 60]:\n            tmi_node.ut = node_ut_base + dt\n            tmi_node.prograde = transfer_dv + ddv\n            try:\n                next_orbit = tmi_node.orbit.next_orbit\n                if next_orbit is not None and next_orbit.body.name == \'Mun\':\n                    peri = next_orbit.periapsis_altitude\n                    if peri != peri:\n                        peri = 500000.0\n                    score = abs(peri - TARGET_MUN_PERIAPSIS)\n                else:\n                    score = tmi_node.orbit.distance_at_closest_approach(mun.orbit)\n            except Exception:\n                score = float(\'inf\')\n            if score < best_score:\n                best_score = score\n                best_ut = node_ut_base + dt\n                best_dv = transfer_dv + ddv\n\n    tmi_node.ut = best_ut\n    tmi_node.prograde = best_dv\n    execute_node(tmi_node, \'TMI\')\n\n    if vessel.orbit.next_orbit is None or vessel.orbit.next_orbit.body.name != \'Mun\':\n        raise RuntimeError(\'Failed Phase 3 verification: no Mun encounter after TMI.\')\n\n    # Coast to Mun SOI\n    PHASE_NAME = \'COAST_TO_MUN\'\n    while vessel.orbit.body.name == \'Kerbin\':\n        t_soi = vessel.orbit.time_to_soi_change\n        if not math.isnan(t_soi) and t_soi > 180.0:\n            sc.warp_to(ut_stream() + t_soi - 60.0)\n        log_status()\n        time.sleep(0.2)\n\n    # Phase 4 — Mun orbit insertion at periapsis\n    PHASE_NAME = \'MUN_APPROACH\'\n    while vessel.orbit.time_to_periapsis > 120.0:\n        if vessel.orbit.time_to_periapsis > 300.0:\n            sc.warp_to(ut_stream() + vessel.orbit.time_to_periapsis - 120.0)\n        log_status()\n        time.sleep(0.2)\n\n    mu_m = vessel.orbit.body.gravitational_parameter\n    r_p = vessel.orbit.periapsis\n    a_current = vessel.orbit.semi_major_axis\n    a_target = r_p\n    v_current = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a_current))\n    v_circular = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a_target))\n    moi_dv = max(v_current - v_circular, 0.0)\n    moi_node = control.add_node(ut_stream() + vessel.orbit.time_to_periapsis, prograde=-moi_dv)\n    execute_node(moi_node, \'MOI\')\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(\'Failed Phase 4: not orbiting Mun after insertion burn.\')\n\n    if vessel.orbit.apoapsis_altitude > MAX_MUN_APOAPSIS:\n        PHASE_NAME = \'MUN_TRIM\'\n        while vessel.orbit.time_to_periapsis > 30.0:\n            log_status()\n            time.sleep(0.2)\n        r_p = vessel.orbit.periapsis\n        a1 = vessel.orbit.semi_major_axis\n        r_ap_target = vessel.orbit.body.equatorial_radius + 200000.0\n        a2 = 0.5 * (r_p + r_ap_target)\n        v1 = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a1))\n        v2 = math.sqrt(mu_m * (2.0 / r_p - 1.0 / a2))\n        trim_node = control.add_node(ut_stream() + vessel.orbit.time_to_periapsis, prograde=(v2 - v1))\n        execute_node(trim_node, \'MUN_TRIM\')\n\n    if vessel.orbit.body.name != \'Mun\' or vessel.orbit.periapsis_altitude < 10000.0 or vessel.orbit.apoapsis_altitude > MAX_MUN_APOAPSIS:\n        raise RuntimeError(\'Final Mun orbit does not satisfy PE >= 10 km and AP <= 500 km.\')\n\n    PHASE_NAME = \'MUN_ORBIT_VERIFY\'\n    verify_until = ut_stream() + vessel.orbit.period\n    control.throttle = 0.0\n    while ut_stream() < verify_until:\n        if vessel.thrust > 0.1:\n            raise RuntimeError(\'Unexpected thrust during final orbit verification.\')\n        log_status()\n        time.sleep(0.5)\n\n    PHASE_NAME = \'MISSION_COMPLETE\'\n    log_status()\n    print(\'Mission success: stable Mun orbit sustained for one full orbit without thrust.\')\n    sys.stdout.flush()\n\n\nif __name__ == \'__main__\':\n    main()\n'})
