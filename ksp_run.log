P:\n            raise RuntimeError(f\'Apoapsis too high: {vessel.orbit.apoapsis_altitude:.0f}\')\n        time.sleep(0.5)\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    kerbin = sc.bodies[\'Kerbin\']\n    mun = sc.bodies[\'Mun\']\n\n    vessel.control.sas = False\n    vessel.control.rcs = False\n    vessel.control.throttle = 0.0\n    vessel.auto_pilot.disengage()\n    time.sleep(0.5)\n\n    phase = {\'name\': \'PRELAUNCH\'}\n    log = logger(conn, vessel, phase)\n\n    ascent(conn, vessel, log, phase)\n    circularize(conn, vessel, kerbin, log, phase)\n    tmi(conn, vessel, kerbin, mun, log, phase)\n    perform_moi_when_needed(conn, vessel, mun, log, phase)\n    verify(conn, vessel, log, phase)\n\n    phase[\'name\'] = \'MISSION_SUCCESS\'\n    log(force=True)\n    print(\'MISSION SUCCESS: stable Mun orbit sustained for one full orbit.\')\n\n\nif __name__ == \'__main__\':\n    try:\n        main()\n    except Exception as exc:\n        print(\'MISSION FAILURE\')\n        print(str(exc))\n        traceback.print_exc()\n        raise\n'})
