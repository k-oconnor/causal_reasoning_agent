01:53:29  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_3.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTELEMETRY_INTERVAL = 5.0\nTARGET_AP = 90000.0\nTARGET_PE = 80000.0\nTARGET_MUN_PE = 30000.0\nMAX_MUN_AP = 500000.0\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef vis_viva(mu, r, a):\n    return math.sqrt(mu * (2.0 / r - 1.0 / a))\n\n\ndef burn_time(vessel, dv):\n    thrust = max(vessel.available_thrust, vessel.max_thrust, 1.0)\n    isp = max(vessel.specific_impulse * 9.82, 1.0)\n    m0 = vessel.mass\n    mf = m0 / math.exp(dv / isp)\n    flow = thrust / isp\n    return max((m0 - mf) / flow, 0.1)\n\n\ndef fuel_percent(vessel):\n    try:\n        r = vessel.resources\n        cur = r.amount(\'LiquidFuel\') + r.amount(\'Oxidizer\')\n        maxv = r.max(\'LiquidFuel\') + r.max(\'Oxidizer\')\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef make_logger(conn, vessel, phase):\n    start_ut = conn.space_center.ut\n    last_ut = {\'v\': -1e9}\n\n    def log(force=False):\n        ut = conn.space_center.ut\n        if not force and ut - last_ut[\'v\'] < TELEMETRY_INTERVAL:\n            return\n        last_ut[\'v\'] = ut\n        fl = vessel.flight()\n        print(\n            f"[T+{ut-start_ut:.0f}s] ALT={fl.mean_altitude:.0f}m | SURF_ALT={fl.surface_altitude:.0f}m | "\n            f"SPD={fl.speed:.1f}m/s | AP={vessel.orbit.apoapsis_altitude:.0f}m | PE={vessel.orbit.periapsis_altitude:.0f}m | "\n            f"BODY={vessel.orbit.body.name} | FUEL={fuel_percent(vessel):.1f}% | PHASE={phase[\'name\']}"\n        )\n    return log\n\n\ndef wait_for_liftoff(vessel, log):\n    deadline = time.time() + 12.0\n    while time.time() < deadline:\n        log()\n        if vessel.flight().surface_altitude > 25.0:\n            return\n        time.sleep(0.1)\n    raise RuntimeError(\n        f"Liftoff failure: ALT={vessel.flight().mean_altitude:.0f} SPD={vessel.flight().speed:.1f} indicates insufficient thrust or bad staging"\n    )\n\n\ndef execute_node(conn, vessel, node, log):\n    sc = conn.space_center\n    ap = vessel.auto_pilot\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.0)\n\n    remaining = conn.add_stream(getattr, node, \'remaining_delta_v\')\n    bt = burn_time(vessel, max(node.delta_v, 1.0))\n    start_ut = node.ut - bt / 2.0\n\n    if sc.ut < start_ut - 60:\n        sc.warp_to(start_ut - 20)\n    while sc.ut < start_ut:\n        log()\n        time.sleep(0.05)\n\n    vessel.control.throttle = 1.0\n    while remaining() > 25.0:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.25\n    while remaining() > 3.0:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.08\n    while remaining() > 0.5:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.0\n    node.remove()\n\n\ndef phase_angle(vessel, mun, frame):\n    vp = vessel.position(frame)\n    mp = mun.position(frame)\n    ang_v = math.atan2(vp[1], vp[0])\n    ang_m = math.atan2(mp[1], mp[0])\n    return (ang_m - ang_v) % (2 * math.pi)\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    kerbin = sc.bodies[\'Kerbin\']\n    mun = sc.bodies[\'Mun\']\n    phase = {\'name\': \'PRELAUNCH\'}\n    log = make_logger(conn, vessel, phase)\n\n    control = vessel.control\n    ap = vessel.auto_pilot\n    control.sas = False\n    control.rcs = False\n    control.throttle = 0.0\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n    time.sleep(1.0)\n\n    # Launch\n    phase[\'name\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    wait_for_liftoff(vessel, log)\n\n    turn_start = 1000.0\n    turn_end = 45000.0\n    staged = False\n\n    while True:\n        fl = vessel.flight()\n        alt = fl.mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        q = fl.dynamic_pressure\n\n        frac = clamp((alt - turn_start) / (turn_end - turn_start), 0.0, 1.0)\n        pitch = 90.0 - 82.0 * frac\n        pitch = max(pitch, 5.0)\n        ap.target_pitch_and_heading(pitch, 90)\n\n        if q > 30000:\n            control.throttle = 0.5\n        elif q > 20000:\n            control.throttle = 0.7\n        else:\n            control.throttle = 1.0\n\n        if not staged and vessel.available_thrust < 10.0 and fuel_percent(vessel) < 40.0:\n            control.activate_next_stage()\n            staged = True\n            time.sleep(2.0)\n\n        log()\n        if ap_alt >= TARGET_AP and alt < 70000:\n            break\n        if fl.surface_altitude < 0:\n            raise RuntimeError(\'Ascent failure: terrain impact\')\n        time.sleep(0.05)\n\n    control.throttle = 0.0\n\n    # Coast to apoapsis\n    phase[\'name\'] = \'COAST_TO_AP\'\n    if vessel.orbit.time_to_apoapsis > 60:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_apoapsis - 20)\n    while vessel.orbit.time_to_apoapsis > 12:\n        log()\n        time.sleep(0.1)\n\n    # Circularize directly with upper stage\n    phase[\'name\'] = \'CIRCULARIZATION\'\n    mu = kerbin.gravitational_parameter\n    r = vessel.orbit.apoapsis\n    a1 = vessel.orbit.semi_major_axis\n    dv = vis_viva(mu, r, r) - vis_viva(mu, r, a1) + 10.0\n    node = control.add_node(sc.ut + vessel.orbit.time_to_apoapsis, prograde=dv)\n    execute_node(conn, vessel, node, log)\n\n    if vessel.orbit.periapsis_altitude < 75000 or vessel.orbit.body.name != \'Kerbin\':\n        raise RuntimeError(f"Failed circularization: PE={vessel.orbit.periapsis_altitude:.0f} BODY={vessel.orbit.body.name}")\n\n    # Wait for transfer window ~ phase angle around 1.9 rad (~109 deg)\n    phase[\'name\'] = \'WAIT_TMI_WINDOW\'\n    frame = kerbin.non_rotating_reference_frame\n    target_phase = math.radians(110.0)\n    while True:\n        cur = phase_angle(vessel, mun, frame)\n        err = min((cur - target_phase) % (2*math.pi), (target_phase - cur) % (2*math.pi))\n        log()\n        if err < math.radians(2.0):\n            break\n        time.sleep(0.5)\n\n    # Simple TMI: burn prograde until Mun encounter appears\n    phase[\'name\'] = \'TMI\'\n    ap.reference_frame = vessel.orbital_reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.0)\n    control.throttle = 1.0\n    tmi_start = sc.ut\n    while True:\n        nxt = vessel.orbit.next_orbit\n        log()\n        if nxt is not None and nxt.body.name == \'Mun\':\n            break\n        if sc.ut - tmi_start > 600:\n            control.throttle = 0.0\n            raise RuntimeError(\'TMI failed: no Mun encounter after extended prograde burn\')\n        time.sleep(0.05)\n    control.throttle = 0.0\n\n    # Coast to Mun SOI\n    phase[\'name\'] = \'COAST_TO_MUN\'\n    if not math.isnan(vessel.orbit.time_to_soi_change) and vessel.orbit.time_to_soi_change > 90:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_soi_change - 60)\n    while vessel.orbit.body.name == \'Kerbin\':\n        log()\n        time.sleep(0.2)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f"SOI failure: BODY={vessel.orbit.body.name}")\n\n    # MOI at periapsis, burn retrograde until target orbit achieved\n    phase[\'name\'] = \'MOI\'\n    if vessel.orbit.time_to_periapsis > 90:\n        sc.warp_to(sc.ut + vessel.orbit.time_to_periapsis - 40)\n    while vessel.orbit.time_to_periapsis > 8:\n        log()\n        time.sleep(0.1)\n\n    ap.reference_frame = vessel.orbital_reference_frame\n    ap.target_direction = (0, -1, 0)\n    ap.engage()\n    time.sleep(1.0)\n    control.throttle = 1.0\n    while True:\n        pe = vessel.orbit.periapsis_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            control.throttle = 0.0\n            raise RuntimeError(\'MOI failure: left Mun SOI during insertion\')\n        if pe >= 10000 and ap_alt <= MAX_MUN_AP and vessel.orbit.eccentricity < 0.95:\n            break\n        time.sleep(0.05)\n    control.throttle = 0.0\n\n    if vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n        raise RuntimeError(f"Post-MOI invalid orbit: PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}")\n\n    # Verify one orbit\n    phase[\'name\'] = \'VERIFY_ONE_ORBIT\'\n    end_ut = sc.ut + vessel.orbit.period\n    while sc.ut < end_ut:\n        control.throttle = 0.0\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            raise RuntimeError(\'Verification failure: left Mun orbit\')\n        if vessel.orbit.periapsis_altitude < 10000 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n            raise RuntimeError(f"Verification failure: PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}")\n        time.sleep(0.5)\n\n    phase[\'name\'] = \'MISSION_SUCCESS\'\n    log(force=True)\n    print(\'MISSION SUCCESS: stable Mun orbit sustained for one full orbit.\')\n\n\nif __name__ == \'__main__\':\n    try:\n        main()\n    except Exception as exc:\n        print(\'MISSION FAILURE\')\n        print(str(exc))\n        traceback.print_exc()\n        raise\n'})
