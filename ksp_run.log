01:32:39  INFO      causal_agent.research_planner  |  tool call >> save_file({'filename': 'flight_attempt_2.py', 'content': 'import math\nimport time\nimport traceback\nimport krpc\n\nMISSION_NAME = \'MunMissionAgent\'\nTARGET_LKO_AP = 90000.0\nTARGET_LKO_PE = 75000.0\nTARGET_MUN_PE = 30000.0\nMAX_MUN_AP = 500000.0\nTELEMETRY_INTERVAL = 5.0\n\n\ndef connect():\n    return krpc.connect(name=MISSION_NAME)\n\n\ndef clamp(x, lo, hi):\n    return max(lo, min(hi, x))\n\n\ndef norm(v):\n    return math.sqrt(sum(a * a for a in v))\n\n\ndef dot(a, b):\n    return sum(x * y for x, y in zip(a, b))\n\n\ndef cross(a, b):\n    return (\n        a[1] * b[2] - a[2] * b[1],\n        a[2] * b[0] - a[0] * b[2],\n        a[0] * b[1] - a[1] * b[0],\n    )\n\n\ndef unit(v):\n    n = norm(v)\n    return (0.0, 0.0, 0.0) if n == 0 else tuple(a / n for a in v)\n\n\ndef signed_phase_angle(vessel_pos, vessel_vel, target_pos):\n    vp = unit(vessel_pos)\n    tp = unit(target_pos)\n    orbit_normal = unit(cross(vessel_pos, vessel_vel))\n    c = clamp(dot(vp, tp), -1.0, 1.0)\n    ang = math.acos(c)\n    sign = 1.0 if dot(cross(vp, tp), orbit_normal) >= 0 else -1.0\n    return (sign * ang) % (2.0 * math.pi)\n\n\ndef vis_viva_speed(mu, radius, semi_major_axis):\n    return math.sqrt(mu * (2.0 / radius - 1.0 / semi_major_axis))\n\n\ndef burn_time_for_delta_v(vessel, delta_v):\n    thrust = max(vessel.available_thrust, vessel.max_thrust, 1.0)\n    isp = max(vessel.specific_impulse * 9.82, 1.0)\n    m0 = vessel.mass\n    mf = m0 / math.exp(delta_v / isp)\n    flow_rate = thrust / isp\n    return max((m0 - mf) / flow_rate, 0.1)\n\n\ndef fuel_percent(vessel):\n    try:\n        res = vessel.resources\n        lf = res.amount(\'LiquidFuel\')\n        lfm = res.max(\'LiquidFuel\')\n        ox = res.amount(\'Oxidizer\')\n        oxm = res.max(\'Oxidizer\')\n        cur = lf + ox\n        maxv = lfm + oxm\n        return 0.0 if maxv <= 0 else 100.0 * cur / maxv\n    except Exception:\n        return -1.0\n\n\ndef telemetry_printer(conn, vessel, phase_state):\n    start_ut = conn.space_center.ut\n    last = {\'ut\': -1e9}\n\n    def emit(force=False):\n        ut = conn.space_center.ut\n        if (not force) and ut - last[\'ut\'] < TELEMETRY_INTERVAL:\n            return\n        last[\'ut\'] = ut\n        alt = vessel.flight().mean_altitude\n        surf_alt = vessel.flight().surface_altitude\n        spd = vessel.flight().speed\n        ap = vessel.orbit.apoapsis_altitude\n        pe = vessel.orbit.periapsis_altitude\n        body = vessel.orbit.body.name\n        fuel = fuel_percent(vessel)\n        elapsed = ut - start_ut\n        print(f"[T+{elapsed:.0f}s] ALT={alt:.0f}m | SURF_ALT={surf_alt:.0f}m | SPD={spd:.1f}m/s | AP={ap:.0f}m | PE={pe:.0f}m | BODY={body} | FUEL={fuel:.1f}% | PHASE={phase_state[\'phase\']}")\n\n    return emit\n\n\ndef set_rails_warp(sc, factor):\n    try:\n        sc.rails_warp_factor = factor\n    except Exception:\n        pass\n\n\ndef stage_if_needed(vessel, last_stage_time):\n    now = time.time()\n    if now - last_stage_time < 2.0:\n        return last_stage_time\n    if vessel.control.throttle > 0.05 and vessel.available_thrust < 1.0:\n        vessel.control.activate_next_stage()\n        return now\n    active_engines = [e for e in vessel.parts.engines if e.active]\n    if not active_engines:\n        vessel.control.activate_next_stage()\n        return now\n    return last_stage_time\n\n\ndef execute_node(conn, vessel, node, phase_state, log):\n    sc = conn.space_center\n    ap = vessel.auto_pilot\n    ap.reference_frame = node.reference_frame\n    ap.target_direction = (0, 1, 0)\n    ap.engage()\n    time.sleep(1.0)\n    try:\n        ap.wait()\n    except Exception:\n        time.sleep(2.0)\n\n    remaining = conn.add_stream(getattr, node, \'remaining_delta_v\')\n    burn_time = burn_time_for_delta_v(vessel, max(node.delta_v, 1.0))\n    target_ut = node.ut - burn_time / 2.0\n\n    if sc.ut < target_ut - 60.0:\n        set_rails_warp(sc, 4)\n        while sc.ut < target_ut - 20.0:\n            log()\n            time.sleep(0.2)\n        set_rails_warp(sc, 0)\n\n    while sc.ut < target_ut:\n        log()\n        time.sleep(0.05)\n\n    vessel.control.throttle = 1.0\n    while remaining() > 20.0:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.25\n    while remaining() > 2.0:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.08\n    while remaining() > 0.3:\n        log()\n        time.sleep(0.05)\n    vessel.control.throttle = 0.0\n    time.sleep(0.3)\n    node.remove()\n\n\ndef plan_tmi_window(conn, vessel, mun):\n    sc = conn.space_center\n    kerbin = sc.bodies[\'Kerbin\']\n    frame = kerbin.non_rotating_reference_frame\n    mu = kerbin.gravitational_parameter\n    r_departure = vessel.orbit.semi_major_axis\n    r_target = mun.orbit.semi_major_axis\n    a_transfer = 0.5 * (r_departure + r_target)\n    t_transfer = math.pi * math.sqrt(a_transfer ** 3 / mu)\n    target_rate = math.sqrt(mu / r_target ** 3)\n    vessel_rate = math.sqrt(mu / r_departure ** 3)\n    required = (math.pi - target_rate * t_transfer) % (2.0 * math.pi)\n\n    vessel_pos = vessel.position(frame)\n    vessel_vel = vessel.velocity(frame)\n    mun_pos = mun.position(frame)\n    current = signed_phase_angle(vessel_pos, vessel_vel, mun_pos)\n    rel_rate = vessel_rate - target_rate\n    phase_error = (required - current) % (2.0 * math.pi)\n    wait_time = phase_error / rel_rate if rel_rate > 0 else 0.0\n    return wait_time\n\n\ndef find_mun_encounter(conn, vessel, mun, base_ut, base_dv):\n    best = None\n    best_score = 1e30\n    for dt in [-180, -90, -45, 0, 45, 90, 180]:\n        for ddv in [-120, -60, -30, 0, 30, 60, 120]:\n            node = vessel.control.add_node(base_ut + dt, prograde=base_dv + ddv)\n            try:\n                nxt = node.orbit.next_orbit\n                score = node.orbit.distance_at_closest_approach(mun.orbit)\n                hit = nxt is not None and nxt.body.name == \'Mun\'\n                if hit:\n                    score -= 1e9\n                if score < best_score:\n                    best_score = score\n                    best = (base_ut + dt, base_dv + ddv, hit, score)\n            except Exception:\n                pass\n            finally:\n                node.remove()\n    return best\n\n\ndef main():\n    conn = connect()\n    sc = conn.space_center\n    vessel = sc.active_vessel\n    bodies = sc.bodies\n    kerbin = bodies[\'Kerbin\']\n    mun = bodies[\'Mun\']\n\n    phase_state = {\'phase\': \'PRELAUNCH\'}\n    log = telemetry_printer(conn, vessel, phase_state)\n\n    print(f\'Vessel: {vessel.name}\')\n\n    control = vessel.control\n    ap = vessel.auto_pilot\n    control.sas = False\n    control.rcs = False\n    control.gear = False\n    control.throttle = 0.0\n    ap.engage()\n    ap.target_pitch_and_heading(90, 90)\n    time.sleep(2.0)\n\n    phase_state[\'phase\'] = \'LAUNCH\'\n    control.throttle = 1.0\n    control.activate_next_stage()\n    time.sleep(0.5)\n\n    # verify real liftoff quickly to catch pad-thrust problems\n    liftoff_deadline = time.time() + 10.0\n    while time.time() < liftoff_deadline:\n        log()\n        if vessel.flight().speed > 5.0 or vessel.flight().surface_altitude > 20.0:\n            break\n        time.sleep(0.1)\n    else:\n        raise RuntimeError(\n            f"Liftoff failure: SPD={vessel.flight().speed:.1f} ALT={vessel.flight().mean_altitude:.0f} TWR/thrust insufficient or clamps not released"\n        )\n\n    last_stage_time = time.time()\n    turn_start_alt = 1500.0\n    turn_end_alt = 45000.0\n\n    while True:\n        alt = vessel.flight().mean_altitude\n        ap_alt = vessel.orbit.apoapsis_altitude\n        q = vessel.flight().dynamic_pressure\n\n        frac = clamp((alt - turn_start_alt) / (turn_end_alt - turn_start_alt), 0.0, 1.0)\n        target_pitch = 90.0 - 82.0 * frac\n        target_pitch = max(target_pitch, 8.0)\n        ap.target_pitch_and_heading(target_pitch, 90)\n\n        if q > 30000:\n            control.throttle = 0.45\n        elif q > 20000:\n            control.throttle = 0.65\n        elif q > 12000:\n            control.throttle = 0.85\n        else:\n            control.throttle = 1.0\n\n        last_stage_time = stage_if_needed(vessel, last_stage_time)\n        log()\n\n        if ap_alt >= TARGET_LKO_AP and alt < 70000.0:\n            break\n        if vessel.flight().surface_altitude < -5:\n            raise RuntimeError(\'Launch failure: vessel impacted terrain\')\n        time.sleep(0.05)\n\n    control.throttle = 0.0\n\n    phase_state[\'phase\'] = \'COAST_TO_AP\'\n    set_rails_warp(sc, 4)\n    while vessel.orbit.time_to_apoapsis > 25.0:\n        log()\n        time.sleep(0.1)\n    set_rails_warp(sc, 0)\n\n    phase_state[\'phase\'] = \'CIRCULARIZATION\'\n    mu = vessel.orbit.body.gravitational_parameter\n    r = vessel.orbit.apoapsis\n    a1 = vessel.orbit.semi_major_axis\n    a2 = r\n    circ_dv = max(0.0, vis_viva_speed(mu, r, a2) - vis_viva_speed(mu, r, a1) + 15.0)\n    node = control.add_node(sc.ut + vessel.orbit.time_to_apoapsis, prograde=circ_dv)\n    execute_node(conn, vessel, node, phase_state, log)\n\n    if vessel.orbit.periapsis_altitude < TARGET_LKO_PE or vessel.orbit.body.name != \'Kerbin\':\n        raise RuntimeError(f\'Failed circularization: PE={vessel.orbit.periapsis_altitude:.0f} BODY={vessel.orbit.body.name}\')\n\n    phase_state[\'phase\'] = \'WAIT_TMI_WINDOW\'\n    wait_time = plan_tmi_window(conn, vessel, mun)\n    if wait_time > 120:\n        sc.warp_to(sc.ut + wait_time - 60)\n    while True:\n        wait_time = plan_tmi_window(conn, vessel, mun)\n        log()\n        if wait_time < 30.0:\n            break\n        time.sleep(0.2)\n\n    phase_state[\'phase\'] = \'PLAN_TMI\'\n    r1 = vessel.orbit.semi_major_axis\n    r2 = mun.orbit.semi_major_axis\n    mu_k = kerbin.gravitational_parameter\n    a_transfer = 0.5 * (r1 + r2)\n    v_circ = math.sqrt(mu_k / r1)\n    v_trans = math.sqrt(mu_k * (2.0 / r1 - 1.0 / a_transfer))\n    tmi_dv = max(0.0, v_trans - v_circ)\n    base_ut = sc.ut + vessel.orbit.time_to_apoapsis\n    best = find_mun_encounter(conn, vessel, mun, base_ut, tmi_dv)\n    if best is None:\n        best = (base_ut, tmi_dv + 50.0, False, 0.0)\n\n    node = control.add_node(best[0], prograde=best[1])\n    execute_node(conn, vessel, node, phase_state, log)\n\n    phase_state[\'phase\'] = \'CHECK_ENCOUNTER\'\n    t_end = time.time() + 45.0\n    while time.time() < t_end:\n        log()\n        nxt = vessel.orbit.next_orbit\n        if nxt is not None and nxt.body.name == \'Mun\':\n            break\n        time.sleep(0.2)\n    nxt = vessel.orbit.next_orbit\n    if nxt is None or nxt.body.name != \'Mun\':\n        raise RuntimeError(\'TMI failed: no Mun encounter predicted after burn\')\n\n    phase_state[\'phase\'] = \'COAST_TO_MUN\'\n    t_soi = vessel.orbit.time_to_soi_change\n    if not math.isnan(t_soi) and t_soi > 120.0:\n        sc.warp_to(sc.ut + t_soi - 90.0)\n    while vessel.orbit.body.name == \'Kerbin\':\n        log()\n        time.sleep(0.2)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(f\'Unexpected SOI state: BODY={vessel.orbit.body.name}\')\n\n    phase_state[\'phase\'] = \'MOI_SETUP\'\n    while vessel.orbit.time_to_periapsis > 90.0:\n        log()\n        time.sleep(0.2)\n\n    mu_m = mun.gravitational_parameter\n    r_peri = vessel.orbit.periapsis\n    a_hyp = vessel.orbit.semi_major_axis\n    v_peri = vis_viva_speed(mu_m, r_peri, a_hyp)\n    target_radius = mun.equatorial_radius + TARGET_MUN_PE\n    v_target = math.sqrt(mu_m / target_radius)\n    moi_dv = max(0.0, v_peri - v_target + 10.0)\n\n    phase_state[\'phase\'] = \'MOI\'\n    node = control.add_node(sc.ut + vessel.orbit.time_to_periapsis, prograde=-moi_dv)\n    execute_node(conn, vessel, node, phase_state, log)\n\n    if vessel.orbit.body.name != \'Mun\':\n        raise RuntimeError(\'MOI failed: not orbiting Mun after burn\')\n    if vessel.orbit.periapsis_altitude < 10000.0 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n        raise RuntimeError(f\'Post-MOI orbit invalid: PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}\')\n\n    phase_state[\'phase\'] = \'VERIFY_ONE_ORBIT\'\n    end_ut = sc.ut + vessel.orbit.period\n    while sc.ut < end_ut:\n        control.throttle = 0.0\n        log()\n        if vessel.orbit.body.name != \'Mun\':\n            raise RuntimeError(\'Verification failure: left Mun orbit\')\n        if vessel.orbit.periapsis_altitude < 10000.0 or vessel.orbit.apoapsis_altitude > MAX_MUN_AP:\n            raise RuntimeError(f\'Verification failure: PE={vessel.orbit.periapsis_altitude:.0f} AP={vessel.orbit.apoapsis_altitude:.0f}\')\n        time.sleep(0.5)\n\n    phase_state[\'phase\'] = \'MISSION_SUCCESS\'\n    log(force=True)\n    print(\'MISSION SUCCESS: stable Mun orbit sustained for one full orbit.\')\n\n\nif __name__ == \'__main__\':\n    try:\n        main()\n    except Exception as exc:\n        print(\'MISSION FAILURE\')\n        print(str(exc))\n        traceback.print_exc()\n        raise\n'})
